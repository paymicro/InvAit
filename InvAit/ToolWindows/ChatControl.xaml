<UserControl x:Class="InvAit.ToolWindows.ChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             toolkit:Themes.UseVsTheme="True"
             Background="{DynamicResource {x:Static shell:VsBrushes.WindowKey}}"
             d:DesignHeight="450" d:DesignWidth="400" UseLayoutRounding="True">
    
    <!-- WebView -->
    <ContentPresenter x:Name="WebViewHost"
                      Focusable="True"
                      KeyboardNavigation.IsTabStop="True"
                      KeyboardNavigation.TabNavigation="Once"/>
</UserControl>
