@using Microsoft.Extensions.Options
@using UIBlazor.Components
@using UIBlazor.Services
@using UIBlazor.Services.Settings
@using UIBlazor.Services.Settings

<HeadContent>
	<RadzenTheme Theme="standard-dark" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="css/markdown.css" />
</HeadContent>

<RadzenComponents />

<RadzenLayout>
	<RadzenBody>
		<AIChat Title="InvGen Chat"
				ShowClearButton="true"
				class="rz-h-100" />
	</RadzenBody>
</RadzenLayout>

@code
{
	[Inject]
	private IAiSettingsProvider AiSettingsProvider { get; set; } = null!;

	[Inject]
	private IMcpSettingsProvider McpSettingsProvider { get; set; } = null!;

    [Inject]
	private IProfileManager ProfileService { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // инициализация всех настроек
        await AiSettingsProvider.InitializeAsync();
        await McpSettingsProvider.InitializeAsync();
        await ProfileService.InitializeAsync();
    }
}
