@inject IJSRuntime Js

<div id="@_blockId" class="markdown-content">
</div>

@code {
    [Parameter] public string Content { get; set; } = string.Empty;

    private readonly string _blockId = $"md-{Guid.NewGuid()}";
    private string _lastRenderedContent = string.Empty;

    protected override bool ShouldRender() => Content != _lastRenderedContent;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Content != _lastRenderedContent)
        {
            _lastRenderedContent = Content;
            try 
            {
                await Js.InvokeVoidAsync("renderMarkdownToElement", _blockId, Content);
            }
            catch (JSException)
            {
                // Ignore JS errors during rendering if element is disposed
            }
        }
    }
}
