@using static UIBlazor.Components.ToolViews.DiffView
@{
    var css = Model.Type switch
    {
        DiffBlockType.SearchHeader => "diff-header-search",
        DiffBlockType.Separator => "diff-header-separator",
        DiffBlockType.ReplaceHeader => "diff-header-replace",
        DiffBlockType.Removed => "diff-line diff-line-removed",
        DiffBlockType.Added => "diff-line diff-line-added",
        _ => "diff-line-context"
    };
}

<div class="@css">
    @if (Model.Type == DiffBlockType.Removed)
    {
        <span class="diff-marker">-</span>
    }
    @if (Model.Type == DiffBlockType.Added)
    {
        <span class="diff-marker">+</span>
    }
    @Model.Content
</div>

@code {
    [Parameter] public DiffBlock Model { get; set; } = default!;

    private string _lastContent = string.Empty;
    private DiffBlockType _lastType;

    protected override bool ShouldRender()
    {
        // Рендерим ТОЛЬКО если контент или тип реально изменились
        if (Model.Content != _lastContent || Model.Type != _lastType)
        {
            _lastContent = Model.Content;
            _lastType = Model.Type;
            return true;
        }
        return false;
    }
}
