@using System.Text
@using DiffPlex
@using DiffPlex.Chunkers
@using DiffPlex.DiffBuilder
@using DiffPlex.DiffBuilder.Model

<div class="diff-view">
    @if (!string.IsNullOrEmpty(FilePath))
    {
        <div @key="@FilePath" class="tool-file-header">@FilePath</div>
    }
    <div class="diff-block">
        @for (var i = 0; i < diffs.Count; i++)
        {
            @if (diffs[i] == null)
            {
                continue;
            }
            @if (i > 0)
            {
                <hr />
            }
            <DiffViewSection Model="diffs[i]" />
        }
    </div>
</div>

@code {
    [Parameter] public List<string> Lines { get; set; } = [];
    [Parameter] public bool IsClosed { get; set; } = true;

    private string? FilePath { get; set; }
    private int blockIndex = 0;
    private List<SideBySideDiffModel?> diffs = [null];
    private bool showDiffSeparator = false;

    private StringBuilder oldText { get; set; } = new();
    private StringBuilder newText { get; set; } = new();
    private bool inSearch = false;
    private bool inReplace = false;
    private bool _changed = false;
    private DateTime _lastRenderTime = DateTime.MinValue;
    private DateTime _lastDiffedTime = DateTime.MinValue;
    private readonly int _interval = 500; // рендерить не чаще
    private double elapsed => (DateTime.Now - _lastRenderTime).TotalMilliseconds;
    private double elapsedDiffed => (DateTime.Now - _lastDiffedTime).TotalMilliseconds;

    protected override bool ShouldRender()
    {
        if (!_changed) return false;

        if (elapsed >= _interval)
        {
            _lastRenderTime = DateTime.Now;
            _changed = false;
            return true;
        }

        // Запускаем отложенную проверку для "последнего вызова"
        _ = DelayRender();
        return false;
    }

    private async Task DelayRender()
    {
        await Task.Delay(_interval);
        StateHasChanged(); // Перезапустит логику ShouldRender
    }

    protected override void OnParametersSet()
    {
        ParseDiff();
    }

    private void ParseDiff()
    {
        if (Lines.Count < 2)
        {
            return;
        }

        // Читаем первую строку для FilePath
        FilePath = Lines[0];
        var currentDiffIndex = diffs.Count - 1;
        foreach (var line in Lines.Skip(blockIndex + 1))
        {
            var typeLine = DetermineType(line);
            switch (typeLine)
            {
                case DiffBlockType.SearchBlock:
                    oldText.AppendLine(line);
                    _changed = true;
                    
                    break;
                case DiffBlockType.ReplaceBlock:
                    newText.AppendLine(line);
                    _changed = true;
                    break;
                case DiffBlockType.ReplaceHeader: 
                    diffs[currentDiffIndex++] = BuildDiff();
                    _lastDiffedTime = DateTime.Now;
                    diffs.Add(null);
                    oldText.Clear();
                    newText.Clear();
                    break;
            }
            blockIndex++;
        }

        if (_changed && elapsedDiffed >= _interval)
        {
            _lastDiffedTime = DateTime.Now;
            diffs[currentDiffIndex] = BuildDiff();
        }

        showDiffSeparator = diffs.Count > 1;
    }

    private SideBySideDiffModel BuildDiff()
    {
        return SideBySideDiffBuilder.Diff(
            Differ.Instance,
            oldText.ToString(),
            newText.ToString(),
            false,
            false,
            lineChunker: LineChunker.Instance,
            wordChunker: CharacterChunker.Instance
        );
    }

    private DiffBlockType DetermineType(string line)
    {
        var trimmed = line.Trim();

        if (!inReplace && trimmed.StartsWith("<<<<<<< SEARCH"))
        {
            inSearch = true;
            inReplace = false;
            return DiffBlockType.SearchHeader;
        }
        if (inSearch && trimmed.StartsWith("======="))
        {
            inSearch = false;
            inReplace = true;
            return DiffBlockType.Separator;
        }
        if (!inSearch && trimmed.StartsWith(">>>>>>> REPLACE"))
        {
            inSearch = false;
            inReplace = false;
            return DiffBlockType.ReplaceHeader;
        }

        if (inSearch)
            return DiffBlockType.SearchBlock;
        if (inReplace)
            return DiffBlockType.ReplaceBlock;

        return DiffBlockType.Context;
    }

    public enum DiffBlockType
    {
        SearchHeader,
        ReplaceHeader,
        Separator,
        SearchBlock,
        ReplaceBlock,
        Context
    }
}
