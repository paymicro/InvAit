@inherits RadzenComponent

@inject ChatService ChatService
@inject DialogService DialogService

<div @ref="@Element" @attributes="Attributes" class="@GetCssClass()" style="@Style" id="@GetId()" >
    <!-- Chat Header -->
    <RadzenStack class="rz-chat-header" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem">
        <UsageIndicators Messages="@Messages" />
        <RadzenStack class="rz-chat-header-actions" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.5rem">
            @if (ProfileManager.Current.Profiles.Count > 0)
            {
                <RadzenDropDown TValue="string" Data="@ProfileManager.Current.Profiles" TextProperty="Name" ValueProperty="Id"
                                Value="@ProfileManager.Current.ActiveProfileId" Change="@OnProfileChange"
                                Placeholder="Select Profile"
                                Style="width: 180px;" />
            }
            <RadzenButton Icon="delete_history" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@ClearChatAsync" Title="Clear chat history" class="rz-chat-header-clear" />
            <RadzenButton Icon="settings" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@OnShowSettingsAsync" Title="Settings" class="rz-chat-header-settings" />
        </RadzenStack>
    </RadzenStack>

    <!-- Chat Messages -->
    <div class="rz-chat-messages">
        @if (Messages.Count == 0)
        {
            <RadzenStack class="rz-chat-empty" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem">
                <RadzenIcon Icon="chat_bubble_outline" class="rz-text-secondary-color" />
                <RadzenText TextStyle="TextStyle.Body2" class="rz-mt-2 rz-text-tertiary-color">@EmptyMessage</RadzenText>
            </RadzenStack>
        }
        else
        {
            @foreach (var message in Messages)
            {
                var isUser = message.Role == ChatMessageRole.User;
                var isTool = message.Role == ChatMessageRole.Tool;
                <div class="rz-chat-message rz-chat-message-@message.Role" @key="message.Id">
                    <RadzenStack class="rz-chat-message-avatar" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0">
                        <span class="rz-chat-avatar-initials" >
                            @if (isUser)
                            {
                                @UserAvatarText
                            }
                            else if (message.Role == ChatMessageRole.Assistant)
                            {
                                <RadzenIcon Icon="robot_2" IconStyle="IconStyle.Info" />
                            }
                            else if (isTool)
                            {
                                <RadzenIcon Icon="design_services" />
                            }
                        </span>
                    </RadzenStack>
                    <RadzenStack Orientation="Orientation.Vertical" AlignItems="@(isUser ? AlignItems.End : AlignItems.Start)" Gap="0.25rem" class="rz-chat-message-content">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="@(isUser ? JustifyContent.End : JustifyContent.Start)" Gap="0.5rem" class="rz-chat-message-info">
                            <div class="rz-chat-message-time">
                                @message.Timestamp.ToString("HH:mm")
                            </div>
                            @if (message.Model != null)
                            {
                                <div class="rz-chat-message-time"> @message.Model </div>
                            }
                        </RadzenStack>
                        @if (!isTool) 
                        {
                            <div class="rz-chat-message-text" style="display: grid; width: 100%; position: relative;">
                                <div class="message-content-wrapper @(message.IsExpanded ? "expanded" : "collapsed")" 
                                     style="grid-area: 1/1; opacity: @(message.IsEditing ? 0 : 1); visibility: @(message.IsEditing ? "hidden" : "visible"); pointer-events: @(message.IsEditing ? "none" : "all");">
                                    @if (!string.IsNullOrEmpty(message.ReasoningContent))
                                    {
                                        <details>
                                        <summary>Размышления...</summary><AiChatMessage Content=@message.ReasoningContent /></details>
                                    }
                                    <AiChatMessage Content=@(message.DisplayContent ?? message.Content) />
                                    
                                    @if (message.Role == ChatMessageRole.Assistant && message.ToolMessages.Any())
                                    {
                                        <div class="message-tool-results rz-mt-2">
                                            @foreach (var toolMsg in message.ToolMessages)
                                            {
                                                <details class="tool-details">
                                                    <summary>@toolMsg.ToolName</summary>
                                                    <pre class="rz-p-2 rz-background-color-base-900 rz-color-white" style="font-size: 0.8rem; border-radius: 4px;">@toolMsg.Content</pre>
                                                </details>
                                            }
                                        </div>
                                    }
                                </div>
                                
                                @if (!message.IsEditing && !message.IsExpanded && !message.IsStreaming)
                                {
                                    <RadzenButton Text="Show More" Icon="expand_more" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                                 class="show-more-button rz-align-self-center" Click="@(() => message.IsExpanded = true)" />
                                }
                                
                                @if (message.IsEditing)
                                {
                                    <div style="grid-area: 1/1; display: flex; flex-direction: column; width: 100%; height: 100%;">
                                        <RadzenTextArea @bind-Value="@message.TempContent" AutoSize="true" Style="width: 100%; min-height: 100px; flex: 1; height: 100%;" class="rz-chat-edit-textarea" />
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" Style="margin-top: 0.5rem;">
                                            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => OnCancelEdit(message))" />
                                            <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(() => OnSaveEditAsync(message))" />
                                        </RadzenStack>
                                    </div>
                                }
                                
                                @if (message.IsStreaming)
                                {
                                    <RadzenIcon Icon="more_horiz" class="rz-chat-message-streaming-icon" />
                                }
                            </div>
                        }
                        else
                        {
                            <details class="tool-details">
                                <summary>@message.ToolName</summary>
                                <pre>
                                    @message.Content
                                </pre>
                            </details>
                        }
                        
                        <!-- Message Actions -->
                        @if (!message.IsStreaming && !message.IsEditing)
                        {
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.25rem" class="rz-chat-message-actions" Style="opacity: 0.4; transition: opacity 0.2s;">
                                <RadzenButton Icon="edit" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Size="ButtonSize.ExtraSmall" 
                                Click="@(() => OnEditMessage(message))" Title="Edit message" />
                                <RadzenButton Icon="delete" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Size="ButtonSize.ExtraSmall" 
                                Click="@(() => OnDeleteMessageAsync(message))" Title="Delete message" />
                                @if (!IsLoading && message == Messages.LastOrDefault(m => m.Role == ChatMessageRole.Assistant))
                                {
                                    <RadzenButton Icon="refresh" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Size="ButtonSize.ExtraSmall" 
                                    Click="@OnRegenerateLastAsync" Title="Regenerate response" />
                                }
                            </RadzenStack>
                        }
                    </RadzenStack>
                </div>
            }
        }
    </div>

    <!-- Chat Input -->
    <AiChatInput
        IsLoading="IsLoading"
        SendMessage="SendMessageAsync"
        Cancel="CancelResponceAsync">
    </AiChatInput>
</div>
