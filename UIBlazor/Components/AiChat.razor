@inherits RadzenComponent

@inject IChatService ChatService
@inject DialogService DialogService

<div @ref="@Element" @attributes="Attributes" class="@GetCssClass()" style="@Style" id="@GetId()" >
    <!-- Chat Header -->
    <RadzenStack class="rz-chat-header" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem">
        <UsageIndicators Messages="@Messages" />
        <RadzenStack class="rz-chat-header-actions" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.5rem">
            @if (ProfileManager.Current.Profiles.Count > 0)
            {
                <RadzenDropDown TValue="string" Data="@ProfileManager.Current.Profiles" TextProperty="Name" ValueProperty="Id"
                                Value="@ProfileManager.Current.ActiveProfileId" Change="@OnProfileChangeAsync"
                                Placeholder="Select Profile"
                                Style="width: 180px;" />
            }
            <RadzenButton Icon="add_comment" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@NewSessionAsync" Title="New session" class="rz-chat-header-new" />
            <RadzenButton Icon="history" Disabled="@(_recentSessions.Count == 0)" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@OpenSessionsDialogAsync" Title="Session history" class="rz-chat-header-history" />
            <RadzenButton Icon="settings" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@OnShowSettingsAsync" Title="Settings" class="rz-chat-header-settings" />
        </RadzenStack>
    </RadzenStack>

    <!-- Chat Messages -->
    <div class="rz-chat-messages" id="chat-messages">
        @if (Messages.Count == 0)
        {
            <RecentSessionsPicker ShowTitle=true />
        }
        else
        {
            var lastMessage = Messages.LastOrDefault();
            @foreach (var message in Messages)
            {
                <ChatMessageView
                    @key="message.Id"
                    Message="message"
                    IsLast="(message == lastMessage)"
                    IsLoading="IsLoading"
                    OnToolApproval="HandleToolApprovalAsync"
                    OnExecutePlan="ExecutePlanAsync"
                    OnEdit="((m) => OnEditMessage(m))"
                    OnCancelEdit="((m) => OnCancelEdit(m))"
                    OnSaveEdit="OnSaveEditAsync"
                    OnDelete="OnDeleteMessageAsync"
                    OnRegenerate="OnRegenerateLastAsync" />
            }
        }
    </div>

    <!-- Chat Input -->
    <AiChatInput
        IsLoading="IsLoading"
        SendMessage="SendMessageAsync"
        Cancel="CancelResponceAsync">
    </AiChatInput>
</div>
