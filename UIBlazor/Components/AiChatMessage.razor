@inject IJSRuntime Js

<div id="@_messageId" class="markdown-content">
    @((MarkupString)_processedContent)
</div>

@code {
    [Parameter] public string Content { get; set; } = string.Empty;

    private readonly string _messageId = $"msg-{Guid.NewGuid()}";
    private string _lastRenderedContent = string.Empty;
    private string _processedContent = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Рендерим только если контент реально изменился (стриминг)
        if (Content != _lastRenderedContent)
        {
            _lastRenderedContent = Content;
            await Js.InvokeVoidAsync("renderMarkdownToElement", _messageId, Content);
        }
    }
}