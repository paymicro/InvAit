@using Shared.Contracts.Mcp
@inherits RadzenComponent

<RadzenStack Gap="0.5rem">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <CheckBox Text="Enable MCP" @bind-Value="@McpSettingsProvider.Current.Enabled" @bind-Value:after="OnMcpEnabledChanged" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem" JustifyContent="JustifyContent.End">
            <RadzenButton Icon="edit_note" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Click="@OnOpenMcpSettings" />
            <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@OnReloadMcpSettings" />
        </RadzenStack>
    </RadzenStack>

    @if (McpSettingsProvider.Current.Enabled)
    {
        @if (!McpSettingsProvider.Current.Servers.Any())
        {
            <RadzenText TextStyle="TextStyle.Caption" class="server-error-text">
                @SharedResource.NoMCP
            </RadzenText>
        }

        @foreach (var server in McpSettingsProvider.Current.Servers)
        {
            var hasError = McpSettingsProvider.Current.ServerErrors.TryGetValue(server.Name, out var errorMsg);
            var borderColor = hasError ? "var(--rz-error-color)" : "var(--rz-border-color)";
            var serverStyle = $"border: 1px solid {borderColor}; border-radius: var(--rz-border-radius);";

            <RadzenStack Gap="0.5rem" Style="@serverStyle">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <CheckBox Text="@server.Name" @bind-Value="@server.Enabled" @bind-Value:after="OnMcpToolSettingChanged" />
                    </RadzenStack>
                    <ApprovalModeSelector Value="@GetMcpServerApprovalMode(server)" Disabled="@(!server.Enabled)"
                                          ValueChanged="@(mode => OnMcpServerApprovalChanged(server, mode))" />
                </RadzenStack>

                @if (hasError && !string.IsNullOrEmpty(errorMsg))
                {
                    <RadzenStack class="server-error-text">
                        <strong>Error:</strong> @errorMsg
                    </RadzenStack>
                }

                @if (server.Enabled)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" Style="padding-left: 2rem;">
                        <RadzenBadge Text="@server.Transport" />
                        @if (hasError)
                        {
                            <RadzenBadge Text="@SharedResource.Error" Style="font-size: 0.7rem; background: var(--rz-error-color);" />
                        }
                        else if (server.Enabled && server.Tools.Any())
                        {
                            <RadzenBadge Text="@SharedResource.Ready" Style="font-size: 0.7rem; background: var(--rz-success-color);" />
                        }
                    </RadzenStack>
                    <RadzenStack Gap="0.2rem" class="server-commands">
                        @if (server.Transport == "stdio")
                        {
                            <div>Command: @server.Command @(string.Join(" ", server.Args))</div>
                        }
                        else
                        {
                            <div>URL: @server.Url</div>
                        }
                        @if (server.Env.Any())
                        {
                            <div>Env: @server.Env.Count variable(s)</div>
                        }
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem" Style="padding-left: 2rem;">
                        <RadzenButton Text="@SharedResource.RefreshTools" Icon="sync" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => OnRefreshMcpTools(server))" IsBusy="@(_refreshingServerId == server.Name)" />
                    </RadzenStack>

                    @if (server.Tools.Any())
                    {
                        <RadzenAccordion Style="margin-top: 0.3rem; border: none;">
                            <Items>
                                <RadzenAccordionItem Text="@SharedResource.Tools" Icon="build">
                                    <RadzenStack Gap="0.5rem">
                                        @foreach (var tool in server.Tools)
                                        {
                                            <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
                                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                                                    <CheckBox Text="@tool.Name" @bind-Value="@tool.Enabled" @bind-Value:after="OnMcpToolSettingChanged" />
                                                    <RadzenButton Icon="science" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Base" Click="@(() => TestRun(server.Name, tool))" />
                                                </RadzenStack>
                                                <RadzenText TextStyle="TextStyle.Caption" class="tool-description">@tool.Description</RadzenText>
                                            </RadzenStack>
                                        }
                                    </RadzenStack>
                                </RadzenAccordionItem>
                            </Items>
                        </RadzenAccordion>
                    }
                }
            </RadzenStack>
        }
    }
</RadzenStack>

    @code {
    [Inject] IMcpSettingsProvider McpSettingsProvider { get; set; } = null!;
    [Inject] NotificationService NotificationService { get; set; } = null!;
    [Inject] DialogService DialogService { get; set; } = null!;
    [Inject] IToolManager ToolManager { get; set; } = null!;

    private string? _refreshingServerId;

    private async Task OnMcpEnabledChanged()
    {
        if (!McpSettingsProvider.Current.Enabled)
        {
            await McpSettingsProvider.StopAllAsync();
        }
        await McpSettingsProvider.SaveAsync();
    }

    private async Task OnOpenMcpSettings()
    {
        await McpSettingsProvider.OpenSettingsFileAsync();
    }

    private async Task OnReloadMcpSettings()
    {
        await McpSettingsProvider.LoadMcpFileAsync();
        StateHasChanged();
    }

    private async Task OnRefreshMcpTools(McpServerConfig server)
    {
        _refreshingServerId = server.Name;
        StateHasChanged();

        var result = await McpSettingsProvider.RefreshToolsAsync(server);

        _refreshingServerId = null;

        // Update error state
        if (result.StartsWith("Success"))
        {
            McpSettingsProvider.Current.ServerErrors.Remove(server.Name);
        }
        else
        {
            McpSettingsProvider.Current.ServerErrors[server.Name] = result;
        }

        NotificationService.Notify(new NotificationMessage
        {
            Severity = result.StartsWith("Success") ? NotificationSeverity.Success : NotificationSeverity.Error,
            Summary = result,
            Duration = 4000
        });

        await McpSettingsProvider.SaveAsync();
        StateHasChanged();
    }

    private ToolApprovalMode GetMcpServerApprovalMode(McpServerConfig server)
    {
        return McpSettingsProvider.Current.ServerApprovalModes.TryGetValue(server.Name, out var mode)
            ? mode
            : ToolApprovalMode.Allow;
    }

    private async Task OnMcpServerApprovalChanged(McpServerConfig server, ToolApprovalMode mode)
    {
        McpSettingsProvider.Current.ServerApprovalModes[server.Name] = mode;
        await McpSettingsProvider.SaveAsync();
    }

    private void OnMcpToolSettingChanged()
    {
        // Update server enabled states
        foreach (var server in McpSettingsProvider.Current.Servers)
        {
            McpSettingsProvider.Current.ServerEnabledStates[server.Name] = server.Enabled;
        }

        McpSettingsProvider.Current.ToolDisabledStates.Clear();

        foreach (var server in McpSettingsProvider.Current.Servers)
        {
            foreach (var tool in server.Tools)
            {
                var toolKey = $"{server.Name}:{tool.Name}";
                if (!tool.Enabled)
                {
                    McpSettingsProvider.Current.ToolDisabledStates.Add(toolKey);
                }
            }
        }

        McpSettingsProvider.CallSaveTrigger();
    }

    private async Task TestRun(string serverName, McpToolConfig mcpTool) {
        await DialogService.OpenAsync<MCPTestRun>(
            $"{serverName} - {mcpTool.Name}",
            new Dictionary<string, object?> { { "Tool", mcpTool }, { "ServerName", serverName } },
            new DialogOptions {
                Resizable = true,
                Icon = "science",
                Top = "1em",
                Width = "50em"
            }
        );
    }
}
