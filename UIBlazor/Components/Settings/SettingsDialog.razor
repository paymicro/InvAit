@inherits RadzenComponent

<RadzenTabs RenderMode="TabRenderMode.Client" class="settings">
    <Tabs>
        <RadzenTabsItem Text="@SharedResource.SettingsGeneral">
            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.Subtitle1">@SharedResource.Profile:</RadzenText>
                    <RadzenDropDown Data="@ProfileManager.Current.Profiles" TextProperty="Name" ValueProperty="Id"
                                    @bind-Value="@ProfileManager.Current.ActiveProfileId"
                                    Style="flex: 1;" />
                    <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@OnAddProfile" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@OnDeleteProfile"
                                  Disabled="@(ProfileManager.Current.Profiles.Count <= 1)" />
                </RadzenStack>

                <RadzenFormField Text="@SharedResource.ProfileName" Variant="Variant.Outlined" AllowFloatingLabel="false">
                    <RadzenTextBox @bind-Value="@ProfileManager.ActiveProfile.Name" Immediate Style="width: 100%" />
                </RadzenFormField>

                <RadzenFormField Text="@SharedResource.Provider" Variant="Variant.Outlined" AllowFloatingLabel="false">
                    <RadzenDropDown Disabled @bind-Value="@ProfileManager.ActiveProfile.Provider" Data="@_providers" Style="width: 100%" />
                </RadzenFormField>

                <RadzenFormField Text="@SharedResource.Endpoint" Variant="Variant.Outlined" AllowFloatingLabel="false">
                    <RadzenTextBox @bind-Value="@ProfileManager.ActiveProfile.Endpoint" Style="width: 100%" />
                </RadzenFormField>

                <RadzenFormField Text="ApiKey" Variant="Variant.Outlined" AllowFloatingLabel="false">
                    <RadzenPassword @bind-Value="@ProfileManager.ActiveProfile.ApiKey" Style="width: 100%" />
                </RadzenFormField>

                <RadzenFormField Text="@SharedResource.SelectModel" Variant="Variant.Outlined" AllowFloatingLabel="false">
                    <ChildContent>
                        <ModelSelector />
                    </ChildContent>
                    <End>
                        <RadzenButton
                            Icon="autorenew" Click="UpdateModelsAsync"
                            class="@(_isModelUpdating ? "icon-spin" : "")"
                            Disabled="@_isModelUpdating"
                            ButtonStyle="ButtonStyle.Secondary" />
                    </End>
                </RadzenFormField>

                <CheckBox Text="@SharedResource.UseStream" @bind-Value=@ProfileManager.ActiveProfile.Stream />

                <RadzenStack Gap="0.2rem">
                    <RadzenLabel Text="@SharedResource.MaxTokens" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenSlider @bind-Value="@ProfileManager.ActiveProfile.MaxTokens" Min=1000 Max=30000 Step="1000" Style="width: 100%; height: 20px;" />
                        <RadzenLabel Text="@($"{ProfileManager.ActiveProfile.MaxTokens}")" Style="text-align: right; width: 50px;" />
                    </RadzenStack>
                </RadzenStack>

                <RadzenStack Gap="0.2rem">
                    <RadzenLabel Text="@SharedResource.ContextWindow" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenSlider @bind-Value="@ProfileManager.ActiveProfile.ContextWindow" Min=5000 Max=256000 Step="1000" Style="width: 100%; height: 20px;" />
                        <RadzenLabel Text="@($"{ProfileManager.ActiveProfile.ContextWindow / 1000}K")" Style="text-align: right; width: 50px;" />
                    </RadzenStack>
                </RadzenStack>

                <RadzenStack Gap="0.2rem">
                    <RadzenLabel Text="@SharedResource.Temperature" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenSlider @bind-Value="@ProfileManager.ActiveProfile.Temperature" Min="0" Max="2" Step="0.1" Style="width: 100%; height: 20px;" />
                        <RadzenLabel Text="@Math.Abs(ProfileManager.ActiveProfile.Temperature).ToString("0.0")" Style="text-align: right; width: 50px;" />
                    </RadzenStack>
                </RadzenStack>

                <RadzenFormField Text="@SharedResource.SystemPrompt" Variant="Variant.Outlined" AllowFloatingLabel="false">
                    <RadzenTextArea @bind-Value="@ProfileManager.ActiveProfile.SystemPrompt" Style="min-height: 90px" />
                </RadzenFormField>
                
                <ExtraHeaderPicker />
                <CheckBox Text="@SharedResource.SkipSSL" @bind-Value=@ProfileManager.ActiveProfile.SkipSSL />
            </RadzenStack>
        </RadzenTabsItem>
        <RadzenTabsItem Text="@SharedResource.SettingsTools">
            <RadzenStack Gap="1rem">
                @foreach (var category in _toolCategories)
                {
                    var state = ToolManager.Current.CategoryStates.ContainsKey(category)
                    ? ToolManager.Current.CategoryStates[category]
                    : new ToolCategorySettings();

                    <RadzenStack Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                            <CheckBox Text="@GetCategoryName(category)" @bind-Value="@state.IsEnabled" @bind-Value:after="() => OnCategorySettingChanged(category, state)" />
                            <ApprovalModeSelector Disabled="@(!state.IsEnabled)" @bind-Value="@state.ApprovalMode" @bind-Value:after="() => OnCategorySettingChanged(category, state)" />
                        </RadzenStack>

                        <div class="@(state.IsEnabled ? "category-tools-visible" : "category-tools-hidden")">
                            @if (state.IsEnabled)
                            {
                                var categoryTools = ToolManager.GetAllTools().Where(t => t.Category == category).ToList();
                                if (categoryTools.Count > 1)
                                {
                                    <RadzenAccordion>
                                        <Items>
                                            <RadzenAccordionItem Text="@SharedResource.Tools" Icon="build">
                                                <RadzenStack Gap="0.5rem">
                                                    @foreach (var tool in categoryTools)
                                                    {
                                                        <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
                                                            <CheckBox Text="@tool.Name" @bind-Value="@tool.Enabled" @bind-Value:after="() => OnToolSettingChanged(tool)" />
                                                            <RadzenText TextStyle="TextStyle.Caption" class="tool-description">@tool.Description</RadzenText>
                                                        </RadzenStack>
                                                    }
                                                </RadzenStack>
                                            </RadzenAccordionItem>
                                        </Items>
                                    </RadzenAccordion>
                                }
                            }
                        </div>
                    </RadzenStack>
                }

                <RadzenStack Gap="0.2rem">
                    <RadzenLabel Text="@SharedResource.ToolRequestTimeoutSec" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenSlider @bind-Value="@CommonSettingsProvider.Current.ToolTimeoutMs" Min="20000" Max="600000" Step="1000" Style="width: 100%; height: 20px;" />
                        <RadzenLabel Text="@($"{CommonSettingsProvider.Current.ToolTimeoutMs / 1000} s")" Style="text-align: right; width: 50px;" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>
        </RadzenTabsItem>

        <RadzenTabsItem Text="MCP">
            <MCPSettingsTab />
        </RadzenTabsItem>
        <RadzenTabsItem Text="@SharedResource.SettingsMisc">
            <RadzenStack Gap="1rem">
                <CheckBox Text="@SharedResource.SendCurrentFile" @bind-Value="@CommonSettingsProvider.Current.SendCurrentFile" />
                <CheckBox Text="@SharedResource.SendSolutionsStricture" @bind-Value="@CommonSettingsProvider.Current.SendSolutionsStricture" />
                
                <RadzenStack Gap="0.2rem">
                    <RadzenLabel Text="@SharedResource.MaxRetries" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenSlider @bind-Value="@CommonSettingsProvider.Current.MaxRetries" Min="0" Max="50" Step="1" Style="width: 100%; height: 20px;" />
                        <RadzenLabel Text="@CommonSettingsProvider.Current.MaxRetries.ToString()" Style="text-align: right; width: 50px;" />
                    </RadzenStack>
                </RadzenStack>

                <LanguageSelector />
            </RadzenStack>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code
{
    [Inject] IChatService ChatService { get; set; } = null!;
    [Inject] NotificationService NotificationService { get; set; } = null!;
    [Inject] IToolManager ToolManager { get; set; } = null!;
    [Inject] IProfileManager ProfileManager { get; set; } = null!;
    [Inject] ICommonSettingsProvider CommonSettingsProvider { get; set; } = null!;
    [Inject] DialogService DialogService { get; set; } = null!;

    private readonly ToolCategory[] _toolCategories = [
        ToolCategory.ReadFiles,
        ToolCategory.WriteFiles,
        ToolCategory.DeleteFiles,
        ToolCategory.ModeSwitch,
        ToolCategory.Execution
    ];
    private readonly string[] _providers = ["OpenAI Compatible"];
    bool _isModelUpdating;

    private async Task OnAddProfile()
    {
        var newProfile = new ConnectionProfile();
        ProfileManager.Current.Profiles.Add(newProfile);
        await ProfileManager.ActivateProfileAsync(newProfile.Id, true);
    }

    private async Task OnDeleteProfile()
    {
        if (string.IsNullOrEmpty(ProfileManager.Current.ActiveProfileId))
        {
            return;
        }

        var confirm = await DialogService.Confirm($"{SharedResource.DeleteProfileQuestion} '{ProfileManager.ActiveProfile.Name}'?", SharedResource.DeleteProfile,
           new ConfirmOptions { OkButtonText = SharedResource.Yes, CancelButtonText = SharedResource.No });

        if (confirm == true)
        {
            await ProfileManager.DeleteProfileAsync(ProfileManager.Current.ActiveProfileId);
        }
    }

    private async Task UpdateModelsAsync()
    {
        _isModelUpdating = true;
        try
        {
            var models = await ChatService.GetModelsAsync(CancellationToken.None);
            var list = models.Data.Select(m => m.Id).ToList();
            ProfileManager.ActiveProfile.AvailableModels = list;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = SharedResource.ErrorModelsNotFound,
                Detail = ex.Message,
                Duration = 10_000,
                ShowProgress = true,
            });
        }
        finally
        {
            _isModelUpdating = false;
        }
        StateHasChanged();
    }

    private string GetCategoryName(ToolCategory category)
    {
        return category switch
        {
            ToolCategory.ReadFiles => SharedResource.CategoryReadFiles,
            ToolCategory.WriteFiles => SharedResource.CategoryWriteFiles,
            ToolCategory.DeleteFiles => SharedResource.CategoryDeleteFiles,
            ToolCategory.ModeSwitch => SharedResource.CategoryModeSwitch,
            ToolCategory.Execution => SharedResource.CategoryExecution,
            _ => category.ToString()
        };
    }

    private async Task OnCategorySettingChanged(ToolCategory category, ToolCategorySettings state)
    {
        ToolManager.UpdateCategorySettings(category, state.IsEnabled, state.ApprovalMode);
        await Task.CompletedTask;
    }

    private async Task OnToolSettingChanged(Tool tool)
    {
        ToolManager.ToggleTool(tool.Name, tool.Enabled);
        await Task.CompletedTask;
    }
}
