@implements IDisposable

<RadzenStack Gap="0.2rem">
    <RadzenText TextStyle="TextStyle.Subtitle1">@SharedResource.ExtraHeaders</RadzenText>
    <RadzenDataGrid @ref="_extraHeadersGrid" TItem="HeaderModel" Data="@Headers" AllowColumnResize="true" AllowSorting="true">
        <EmptyTemplate>
            @if (!string.IsNullOrEmpty(ProfileManager.ActiveProfile.ApiKey))
            {
                <RadzenLabel Text="@SharedResource.ExtraHeadersIsEmpty"/>
            }
        </EmptyTemplate>
        <Columns>
            <RadzenDataGridColumn Property="Name" MinWidth="80px" Width="110px" Title="@SharedResource.Header" TextAlign="TextAlign.Center">
                <Template Context="header">
                    <RadzenTextBox @bind-Value="header.Name"
                                   Change="@(() => ProfileManager.CallSaveTrigger())"
                                   Placeholder="@SharedResource.Empty" />
                </Template>
            </RadzenDataGridColumn>
        
            <RadzenDataGridColumn Property="Value" MinWidth="100px" Title="@SharedResource.Value" TextAlign="TextAlign.Center" Resizable="false">
                <Template Context="header">
                    <RadzenTextBox @bind-Value="header.Value"
                                   Change="@(() => ProfileManager.CallSaveTrigger())"
                                   Placeholder="@SharedResource.Empty" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn Width="60px" Sortable="false" TextAlign="TextAlign.Center" Resizable="false">
                <HeaderTemplate>
                    <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="AddHeader" />
                </HeaderTemplate>
                <Template Context="header">
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => RemoveHeader(header))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    [Inject] IProfileManager ProfileManager { get; set; } = null!;

    private RadzenDataGrid<HeaderModel> _extraHeadersGrid = null!;
    private List<HeaderModel> Headers => ProfileManager.ActiveProfile.ExtraHeaders;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ProfileManager.OnSaved += HandleProfileChanged;
    }

    private void AddHeader()
    {
        Headers.Add(new HeaderModel());
        _extraHeadersGrid.Reload();
        ProfileManager.CallSaveTrigger();
    }

    private void RemoveHeader(HeaderModel item)
    {
        Headers.Remove(item);
        _extraHeadersGrid.Reload();
        ProfileManager.CallSaveTrigger();
    }

    private void HandleProfileChanged()
    {
        _extraHeadersGrid.Reload();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ProfileManager.OnSaved -= HandleProfileChanged;
    }
}
