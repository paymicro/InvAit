@using Shared.Contracts.Mcp

<Details Text=@SharedResource.Description" IsRounded>
    <MarkdownBlock Content="@Tool.Description" />
</Details>

<RadzenStack Gap="1em">
    @foreach (var parameter in parameters)
    {
        var key = parameter.Key;
        var value = parameter.Value;
        if (!_values.ContainsKey(key))
        {
            _values[key] = string.Empty;
        }
        var desc = value.Required ? $"* {value.Desc}" : value.Desc;
        <RadzenFormField Text="@desc" Variant="Variant.Outlined" AllowFloatingLabel="false" class="@(value.Required ? "required" : "")">
            <End>
                <RadzenLabel Text="@key" Style="padding-inline: 0.5em" />
            </End>
            <ChildContent>
                <RadzenTextBox
                    Placeholder="@value.Name"
                    @bind-Value="@_values[key]" />
            </ChildContent>
        </RadzenFormField>
    }

    <RadzenButton Text="@Tool.Name" Click="RunMcpToolAsync" IsBusy="@IsBusy" />
    
    @if (!string.IsNullOrEmpty(Result))
    {
        <RadzenText Text="Result" TextStyle="TextStyle.Overline" />
        <MarkdownBlock Content="@Result" />
    }
</RadzenStack>

@code {
    [Inject] IToolManager ToolManager { get; set; } = null!;    
    [Parameter] public string ServerName { get; set; } = null!;
    [Parameter] public McpToolConfig Tool { get; set; } = null!;

    public Dictionary<string, (string Name, string Desc, bool Required)> parameters { get; set; } = [];
    private Dictionary<string, string> _values = [];
    private string Result = string.Empty;
    private bool IsBusy = false;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        parameters = ToolManager.GetParameterNamesFromSchema(Tool.InputSchema);
    }

    private async Task RunMcpToolAsync()
    {
        IsBusy = true;
        var tool = ToolManager.GetMcpTools().FirstOrDefault(t => t.Name == $"mcp__{ServerName}__{Tool.Name}");

        if (tool is not null)
        {
            var vsToolResult = await tool.ExecuteAsync(_values.ToDictionary(k => k.Key, v => (object)v.Value), CancellationToken.None);
#if DEBUG
            vsToolResult = HeadlessMocker.GetVsToolResult(vsToolResult);
#endif
            if (vsToolResult.Success)
            {
                try
                {
                    var mcpToolResult = JsonUtils.Deserialize<MCPToolResult>(vsToolResult.Result);
                    if (mcpToolResult is null)
                    {
                        Result = "## Error";
                    }
                    else
                    {
                        var sb = new StringBuilder();
                        foreach (var content in mcpToolResult.Content)
                        {
                            sb.AppendLine(
                                content.Type switch
                                {
                                    "text" => content.Text,
                                    "image" => $"## Image\n{content.Data}\n##MimeType\n{content.MimeType}",
                                    "resource" => $"## Resource\n{(content.Resource != null ? JsonUtils.Serialize(content.Resource) : null)}",
                                    _ => "## Error - undefined content type"
                                }
                            );
                        }
                        Result = sb.ToString();
                    }
                }
                catch
                {
                    Result = vsToolResult.Result;
                }
            }
            else
            {
                Result = $"## Error: {vsToolResult.ErrorMessage}";
            }
        }
        else
        {
            Result = "## Error: Tool is not find";
        }

        IsBusy = false;
        await InvokeAsync(StateHasChanged);
    }
}
