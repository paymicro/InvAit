@using Radzen
@using Radzen.Blazor
@using Shared.Contracts.Mcp
@using UIBlazor.Services
@using UIBlazor.Services.Settings

<RadzenStack Gap="1.5rem" Style="padding: 1rem;">
    <RadzenFormField Text="Server Name" Variant="Variant.Outlined">
        <RadzenTextBox @bind-Value="@Server.Name" />
    </RadzenFormField>

    <RadzenFormField Text="Transport" Variant="Variant.Outlined">
        <RadzenDropDown @bind-Value="@Server.Transport" Data="@_transports" />
    </RadzenFormField>

    @if (Server.Transport == "stdio")
    {
        <RadzenFormField Text="Command" Variant="Variant.Outlined">
            <RadzenTextBox @bind-Value="@Server.Command" Placeholder="npx" />
        </RadzenFormField>
        <RadzenFormField Text="Arguments" Variant="Variant.Outlined">
            <RadzenTextBox @bind-Value="@Server.Args" Placeholder="modelcontextprotocol/server-memory" />
        </RadzenFormField>
    }
    else
    {
        <RadzenFormField Text="Endpoint" Variant="Variant.Outlined">
            <RadzenTextBox @bind-Value="@Server.Endpoint" Placeholder="http://localhost:3000/sse" />
        </RadzenFormField>
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenButton Text="Refresh Tools" Icon="autorenew" Click="@OnRefreshTools" ButtonStyle="ButtonStyle.Info" Variant="Variant.Flat" BusyText="Refreshing..." IsBusy="@_isRefreshing" />
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="Cancel" Click="@(() => DialogService.Close(false))" ButtonStyle="ButtonStyle.Light" />
            <RadzenButton Text="Save" Click="@(() => DialogService.Close(true))" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>
    </RadzenStack>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <RadzenAlert Title="Status" AlertStyle="@(_statusMessage.StartsWith("Success") ? AlertStyle.Success : AlertStyle.Danger)" Variant="Variant.Flat" Shade="Shade.Lighter">
            @_statusMessage
        </RadzenAlert>
    }
</RadzenStack>

@code {
    [Parameter] public McpServerConfig Server { get; set; } = new();
    [Inject] DialogService DialogService { get; set; } = null!;
    [Inject] IMcpSettingsProvider McpSettingsProvider { get; set; } = null!;

    private readonly List<string> _transports = ["stdio", "http"];
    private bool _isRefreshing;
    private string _statusMessage = string.Empty;

    private async Task OnRefreshTools()
    {
        _isRefreshing = true;
        _statusMessage = string.Empty;
        try
        {
            _statusMessage = await McpSettingsProvider.RefreshToolsAsync(Server.Id);
        }
        finally
        {
            _isRefreshing = false;
        }
    }
}
