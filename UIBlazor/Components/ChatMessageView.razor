@using UIBlazor.Components.Chat

<div class="rz-chat-message rz-chat-message-@Message.Role" @key="Message.Id">
    <RadzenStack class="rz-chat-message-avatar" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0">
        <span class="rz-chat-avatar-initials" >
            @if (Message.Role == ChatMessageRole.User)
            {
                @UserAvatarText
            }
            else if (Message.Role == ChatMessageRole.Assistant)
            {
                <RadzenIcon Icon="robot_2" IconStyle="IconStyle.Info" />
            }
            else if (Message.Role == ChatMessageRole.Tool)
            {
                <RadzenIcon Icon="design_services" />
            }
        </span>
    </RadzenStack>
    <RadzenStack Orientation="Orientation.Vertical" AlignItems="@(Message.Role == ChatMessageRole.User ? AlignItems.End : AlignItems.Start)" Gap="0.25rem" class="rz-chat-message-content">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="@(Message.Role == ChatMessageRole.User ? JustifyContent.End : JustifyContent.Start)" Gap="0.5rem" class="rz-chat-message-info">
            <div class="rz-chat-message-time">
                @Message.Timestamp.ToString("HH:mm")
            </div>
            @if (Message.Model != null)
            {
                <div class="rz-chat-message-time"> @Message.Model </div>
            }
        </RadzenStack>
            <div class="rz-chat-message-text" style="display: grid; width: 100%; position: relative;">
                <div class="message-content-wrapper @(Message.IsExpanded ? "expanded" : "collapsed")" 
                     style="grid-area: 1/1; opacity: @(Message.IsEditing ? 0 : 1); visibility: @(Message.IsEditing ? "hidden" : "visible"); pointer-events: @(Message.IsEditing ? "none" : "all");">

                    <MessageContent Message="@Message" OnToolApproval="@OnToolApproval" />

                    @if (Message.HasPlan)
                    {
                        <div class="plan-box rz-p-3 rz-mt-2 rz-mb-2" style="border: 1px solid var(--rz-primary-light); border-radius: 8px; background: var(--rz-base-background-color);">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" class="rz-mb-2">
                                <RadzenIcon Icon="assignment" IconStyle="IconStyle.Primary" />
                                <RadzenText TextStyle="TextStyle.Subtitle2" Style="margin: 0; color: var(--rz-primary-light);">@SharedResource.ProposedPlan</RadzenText>
                            </RadzenStack>
                            <MarkdownBlock Content="@Message.PlanContent" />
                            @if (!IsLoading)
                            {
                                <RadzenButton Text="@SharedResource.ExecutePlan" Icon="play_arrow" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                                             Click="@(() => OnExecutePlan.InvokeAsync(Message))" class="rz-mt-2" />
                            }
                        </div>
                    }
                </div>
                
                @if (!Message.IsEditing && !Message.IsExpanded && !Message.IsStreaming)
                {
                    <RadzenButton Text="@SharedResource.ShowMore" Icon="expand_more" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                 class="show-more-button rz-align-self-center" Click="@(() => Message.IsExpanded = true)" />
                }
                
                @if (Message.IsEditing)
                {
                    <div style="grid-area: 1/1; display: flex; flex-direction: column; width: 100%; height: 100%;">
                        <RadzenTextArea @bind-Value="@Message.TempContent" AutoSize="true" Style="width: 100%; min-height: 100px; flex: 1; height: 100%;" class="rz-chat-edit-textarea" />
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" Style="margin-top: 0.5rem;">
                            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => OnCancelEdit.InvokeAsync(Message))" />
                            <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(() => OnSaveEdit.InvokeAsync(Message))" />
                        </RadzenStack>
                    </div>
                }
                
                @if (Message.IsStreaming)
                {
                    <RadzenIcon Icon="more_horiz" class="rz-chat-message-streaming-icon" />
                }

                @if (Message.IsRetrying)
                {
                    <div class="retry-countdown" style="margin-top: 0.5rem; color: var(--rz-warning); font-size: 0.85rem; display: flex; align-items: center; gap: 0.25rem;">
                        <RadzenIcon Icon="autorenew" class="rz-spin" Style="font-size: 1rem;" />
                        <span>@SharedResource.RetryIn @Message.RetryCountdown... (@Message.RetryAttempt / @Message.MaxRetryAttempts)</span>
                    </div>
                }
            </div>
        
        <!-- Message Actions -->
        @if (!Message.IsStreaming && !Message.IsEditing)
        {
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.25rem" class="rz-chat-message-actions" Style="opacity: 0.4; transition: opacity 0.2s;">
                <RadzenButton Icon="edit" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Size="ButtonSize.ExtraSmall" 
                              Click="@(() => OnEdit.InvokeAsync(Message))" Title="@SharedResource.MessageEdit" />
                <RadzenButton Icon="delete" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Size="ButtonSize.ExtraSmall" 
                              Click="@(() => OnDelete.InvokeAsync(Message))" Title="@SharedResource.MessageDelete" />
                @if (!IsLoading && IsLast && Message.Role == ChatMessageRole.Assistant)
                {
                    <RadzenButton Icon="refresh" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" Size="ButtonSize.ExtraSmall" 
                                  Click="@OnRegenerate" Title="@SharedResource.MessageRegenerate" />
                }
            </RadzenStack>
        }
    </RadzenStack>
</div>

@code {
    [Parameter] public VisualChatMessage Message { get; set; } = null!;
    [Parameter] public string UserAvatarText { get; set; } = "U"; // TODO сделать что-то поинтереснее
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsLast { get; set; }
    [Parameter] public EventCallback<(string MessageId, string SegmentId, bool Approved)> OnToolApproval { get; set; }
    [Parameter] public EventCallback<VisualChatMessage> OnExecutePlan { get; set; }
    [Parameter] public EventCallback<VisualChatMessage> OnEdit { get; set; }
    [Parameter] public EventCallback<VisualChatMessage> OnCancelEdit { get; set; }
    [Parameter] public EventCallback<VisualChatMessage> OnSaveEdit { get; set; }
    [Parameter] public EventCallback<VisualChatMessage> OnDelete { get; set; }
    [Parameter] public EventCallback OnRegenerate { get; set; }

    private bool _oldIsStreaming;
    private bool _oldIsEditing;
    private bool _oldIsLast;
    private bool _oldIsLoading;
    private bool _oldIsExpanded;
    private int _oldRetryCountdown;
    private string _oldContent = string.Empty;

    protected override bool ShouldRender()
    {
        if (Message.IsStreaming || _oldIsStreaming ||
            Message.IsRetrying || _oldRetryCountdown != Message.RetryCountdown ||
            Message.IsEditing || _oldIsEditing ||
            IsLast || _oldIsLast != IsLast ||
            IsLoading || _oldIsLoading != IsLoading ||
            Message.IsExpanded != _oldIsExpanded ||
            Message.Content != _oldContent)
        {
            return true;
        }

        return false;
    }

    protected override void OnParametersSet()
    {
        _oldIsStreaming = Message.IsStreaming;
        _oldIsEditing = Message.IsEditing;
        _oldIsLast = IsLast;
        _oldIsLoading = IsLoading;
        _oldIsExpanded = Message.IsExpanded;
        _oldRetryCountdown = Message.RetryCountdown;
        _oldContent = Message.Content;
    }
}
