@using System.ComponentModel
@using UIBlazor.Models
@inherits RadzenComponent

<div class="chat-input-wrapper">
    @* Контейнер для чипов (над полем ввода) *@
    @if (tokens.OfType<FileToken>().Any())
    {
        <div class="chips-list">
            @foreach (var token in tokens.OfType<FileToken>())
            {
                <FileChip Token="token" 
                          Icon="@GetFileIcon(token.FileName)" 
                          OnRemoveClick="RemoveToken" />
            }
        </div>
    }

    <div class="input-container">
        @* Поле ввода *@
        <textarea @ref="textareaRef"
                  rows="1"
                  class="text-input"
                  placeholder="@ModePlaceholder"
                  @bind="currentInput"
                  @oninput="HandleInput"
                  @onkeydown="OnKeyDown"
                  @onkeydown:preventDefault="shouldPreventDefault"
                  disabled="@IsLoading"></textarea>

        @* Нижняя панель с кнопками *@
        <div class="input-footer">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween"  AlignItems="AlignItems.Center">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                    <RadzenDropDown TValue="AppMode" class="mode-dropdown" Data="@AppModeValues" @bind-Value="@CurrentMode" />
                    <RadzenDropDown TValue="string" class="model-dropdown"
                                    Data="@(ProfileManager.ActiveProfile.AvailableModels ?? [])"
                                    @bind-Value="@ProfileManager.ActiveProfile.Model"
                                    @bind-Value:after="OnModelChanged"
                                    Placeholder="Model" />
                </RadzenStack>
                
                <RadzenStack Orientation="Orientation.Horizontal" Gap="4px" JustifyContent="JustifyContent.End" AlignItems="AlignItems.Center">
                    <RadzenButton Icon="gavel" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Size="ButtonSize.Small" Click="@OpenRules" Title="@SharedResource.OpenRules" />
                    <RadzenButton Icon="extension" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Size="ButtonSize.Small" Click="@OpenSkills" Title="@SharedResource.OpenSkills" />
                    
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" JustifyContent="JustifyContent.End" AlignItems="AlignItems.Center">
                        <RadzenButton Icon="send"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Variant="Variant.Text"
                                      Visible="@(!IsLoading)"
                                      Disabled="@(!CanSend())"
                                      Click="@OnSendClick"
                                      title="@SharedResource.SendMessage"
                                      class="rz-chat-send-btn" />
                        <RadzenButton Icon="dangerous"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Variant="Variant.Text"
                                      Visible="@IsLoading"
                                      Click="@Cancel.InvokeAsync"
                                      title="@SharedResource.Cancel"
                                      class="rz-chat-cancel-btn" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>
        </div>
    </div>

    @* Всплывающее меню с файлами *@
    @if (filteredFiles.Any())
    {
        <div class="hints-menu">
            <ul class="hints-list">
                @for (int i = 0; i < filteredFiles.Count; i++)
                {
                    var index = i;
                    var file = filteredFiles[i];
                    var isSelected = index == selectedIndex;
                    var fileName = Path.GetFileName(file.Replace('\\', '/'));
                    var fileDir = Path.GetDirectoryName(file.Replace('\\', '/')) ?? "";
                    var icon = GetFileIcon(fileName);
                    <li class="hint-item @(isSelected ? "selected" : "")" 
                        @onclick="() => AddFileToken(file)">
                        <span class="file-icon">@icon</span>
                        <span class="file-name">@fileName</span>
                        <span class="file-path">@fileDir</span>
                    </li>
                }
            </ul>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<string> SendMessage { get; set; }
    [Parameter] public EventCallback<string> Cancel { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    [Inject] private ChatService ChatService { get; set; } = null!;
    [Inject] private IVsCodeContextService VsCodeContextService { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;
    [Inject] private IVsBridge VsBridge { get; set; } = null!;
    [Inject] private IProfileManager ProfileManager { get; set; } = null!;

    private ElementReference textareaRef;
    private List<InputToken> tokens = new();
    private string currentInput = string.Empty;
    private List<string> filteredFiles = new();
    private int selectedIndex = 0;
    private bool shouldPreventDefault;

    private List<AppMode> AppModeValues { get; } = [.. Enum.GetValues<AppMode>()];

    private string ModePlaceholder => CurrentMode switch
    {
        AppMode.Plan => SharedResource.InputPlaceholderPlan,
        AppMode.Agent => SharedResource.InputPlaceholderAgent,
        _ => SharedResource.InputPlaceholder
    };

    private AppMode CurrentMode
    {
        get => ChatService.Session?.Mode ?? AppMode.Chat;
        set => ChatService.Session?.Mode = value;
    }

    private bool CanSend()
    {
        return !IsLoading && (!string.IsNullOrWhiteSpace(currentInput) || tokens.Any());
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        currentInput = e.Value?.ToString() ?? string.Empty;

        // Автоматически изменяем высоту textarea
        await JS.InvokeVoidAsync("autoResizeTextarea", textareaRef);

        // Проверяем, есть ли @ в конце
        if (currentInput.EndsWith(" @"))
        {
            // Показываем все файлы
            var source = VsCodeContextService.CurrentContext?.SolutionFiles ?? 
                         ["test1.cs", "C:\\asdtes\\t2aksjhdgj\\ahsghd hjagshjdg\\ajhsgdahjkg.cs"];
            filteredFiles = source.Take(10).ToList();
            selectedIndex = 0;
        }
        else if (currentInput.Contains('@'))
        {
            // Ищем текст после последнего @
            var lastAtIndex = currentInput.LastIndexOf('@');
            var query = currentInput.Substring(lastAtIndex + 1);

            var source = VsCodeContextService.CurrentContext?.SolutionFiles ?? 
                         ["test1.cs", "C:\\asdtes\\t2aksjhdgj\\ahsghd hjagshjdg\\ajhsgdahjkg.cs"];

            filteredFiles = source
                .Where(f => f.Contains(query, StringComparison.OrdinalIgnoreCase))
                .Take(10)
                .ToList();
            selectedIndex = 0;
        }
        else
        {
            filteredFiles.Clear();
        }
    }

    private async Task AddFileToken(string filePath)
    {
        var fileName = Path.GetFileName(filePath.Replace('\\', '/'));

        // Удаляем @ и текст после него из currentInput
        var lastAtIndex = currentInput.LastIndexOf('@');
        if (lastAtIndex >= 0)
        {
            currentInput = currentInput.Substring(0, lastAtIndex);
        }

        // Добавляем токен файла
        tokens.Add(new FileToken 
        { 
            FilePath = filePath,
            FileName = fileName
        });

        filteredFiles.Clear();
        selectedIndex = 0;

        // Фокус обратно на input
        await FocusInput();
    }

    private async Task RemoveToken(FileToken token)
    {
        tokens.Remove(token);
        await FocusInput();
    }

    private async Task FocusInput()
    {
        try
        {
            await textareaRef.FocusAsync();
        }
        catch { }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (filteredFiles.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedIndex = (selectedIndex + 1) % filteredFiles.Count;
                shouldPreventDefault = true;
                return;
            }
            if (e.Key == "ArrowUp")
            {
                selectedIndex = (selectedIndex - 1 + filteredFiles.Count) % filteredFiles.Count;
                shouldPreventDefault = true;
                return;
            }
            if (e.Key == "Tab" || e.Key == "Enter")
            {
                shouldPreventDefault = true;
                if (selectedIndex >= 0 && selectedIndex < filteredFiles.Count)
                {
                    await AddFileToken(filteredFiles[selectedIndex]);
                }
                return;
            }
            if (e.Key == "Escape")
            {
                shouldPreventDefault = true;
                filteredFiles.Clear();
                return;
            }
        }

        // Enter без Shift/Ctrl — отправка
        if (e is { Key: "Enter", CtrlKey: false, ShiftKey: false } && !filteredFiles.Any())
        {
            shouldPreventDefault = true;
            await OnSendClick();
        }
        else
        {
            shouldPreventDefault = false;
        }
    }

    private async Task OnModelChanged()
        => await ProfileManager.SaveProfileAsync(ProfileManager.ActiveProfile);

    private async Task OnSendClick()
    {
        if (!CanSend()) return;

        // Загружаем содержимое файлов перед отправкой
        foreach (var fileToken in tokens.OfType<FileToken>())
        {
            if (string.IsNullOrEmpty(fileToken.FileContent))
            {
                var readFileTool = await VsBridge.ExecuteToolAsync(
                    BuiltInToolEnum.ReadFiles,
                    new Dictionary<string, object> { { "param1", fileToken.FilePath } });

                fileToken.FileContent = readFileTool.Result;
            }
        }

        // Формируем сообщение для отправки
        var messageBuilder = new System.Text.StringBuilder();

        // Добавляем текущий ввод
        if (!string.IsNullOrWhiteSpace(currentInput))
        {
            messageBuilder.Append(currentInput.Trim());
        }

        // Добавляем файлы с их содержимым
        foreach (var fileToken in tokens.OfType<FileToken>())
        {
            if (messageBuilder.Length > 0)
                messageBuilder.AppendLine();

            messageBuilder.Append(fileToken.GetLlmText());
        }

        var message = messageBuilder.ToString();

        // Очищаем состояние
        currentInput = string.Empty;
        tokens.Clear();
        filteredFiles.Clear();

        // Сбрасываем высоту textarea
        await JS.InvokeVoidAsync("autoResizeTextarea", textareaRef, true);

        await SendMessage.InvokeAsync(message);
    }

    private string GetFileIcon(string fileName)
    {
        var extension = Path.GetExtension(fileName.Replace('\\', '/')).ToLowerInvariant();
        return extension switch
        {
            ".cs" => "📄",
            ".razor" => "⚡",
            ".html" => "🌐",
            ".css" => "🎨",
            ".js" => "📜",
            ".json" => "📋",
            ".xml" => "📋",
            ".txt" => "📝",
            ".md" => "📖",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".svg" => "🖼️",
            ".dll" or ".exe" => "⚙️",
            ".config" => "🔧",
            ".csproj" or ".sln" => "📦",
            _ => "📄"
        };
    }

    public async Task Clear()
    {
        currentInput = string.Empty;
        tokens.Clear();
        filteredFiles.Clear();

        // Сбрасываем высоту textarea
        await JS.InvokeVoidAsync("eval", "arguments[0].style.height = 'auto'", textareaRef);

        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ChatService.OnSessionChanged += HandleSessionChanged;
        VsBridge.OnModeSwitched += HandleModeSwitched;
        ProfileManager.Current.PropertyChanged += HandleProfileChanged;
    }

    private void HandleModeSwitched(AppMode mode)
    {
        CurrentMode = mode;
        InvokeAsync(StateHasChanged);
    }

    private void HandleSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleProfileChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(ProfileOptions.ActiveProfileId))
        {
            // обновление состояния если изменился профиль - для обновления списка моделей
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenRules()
    {
        await VsBridge.ExecuteToolAsync(BasicEnum.OpenFile, new Dictionary<string, object> { { "param1", ".agent/rules.md" } });
    }

    private async Task OpenSkills()
    {
        await VsBridge.ExecuteToolAsync(BasicEnum.OpenFile, new Dictionary<string, object> { { "param1", ".agent/skills/README.md" } });
    }

    public override void Dispose()
    {
        base.Dispose();
        ChatService.OnSessionChanged -= HandleSessionChanged;
        VsBridge.OnModeSwitched -= HandleModeSwitched;
        ProfileManager.Current.PropertyChanged -= HandleProfileChanged;
    }
}
