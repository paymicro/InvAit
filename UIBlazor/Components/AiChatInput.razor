@using System.ComponentModel
@implements IDisposable

<div class="chat-input-wrapper">
    @* Контейнер для чипов (над полем ввода) *@
    @if (_tokens.OfType<FileToken>().Any())
    {
        <div class="chips-list">
            @foreach (var token in _tokens.OfType<FileToken>())
            {
                <FileChip Token="token"
                            Icon="@GetFileIcon(token.FileName)"
                            OnRemoveClick="RemoveTokenAsync" />
            }
        </div>
    }
    <div class="input-container">
        @* Поле ввода *@
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
            <textarea @ref="_textareaRef"
                      rows="1"
                      class="text-input"
                      placeholder="@ModePlaceholder"
                      @bind="_currentInput"
                      @oninput="HandleInputAsync"
                      @onkeydown="OnKeyDown"
                      @onkeydown:preventDefault="_shouldPreventDefault"
                      disabled="@IsLoading"/>
                  
            <div class="misc">
                <RadzenToggleButton @bind-Value="CommonSettingsProvider.Current.SendCurrentFile"
                                    ButtonStyle="ButtonStyle.Base"
                                    Size="ButtonSize.Small"
                                    Variant="Variant.Flat"
                                    title="@SharedResource.SendCurrentFile">
                    <i class="fa-solid fa-file"></i>
                </RadzenToggleButton>
                <RadzenToggleButton @bind-Value="CommonSettingsProvider.Current.SendSolutionsStricture"
                                    ButtonStyle="ButtonStyle.Base"
                                    Size="ButtonSize.Small"
                                    Variant="Variant.Flat"
                                    title="@SharedResource.SendSolutionsStricture">
                    <i class="fa-solid fa-folder-tree"></i>
                </RadzenToggleButton>
            </div>
        </RadzenStack>

        @* Нижняя панель с кнопками *@
        <div class="input-footer">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                    <RadzenDropDown TValue="AppMode" class="mode-dropdown" Data="@AppModeValues" @bind-Value="@ChatService.Session.Mode" @bind-Value:after="OnModeChanged" />
                    <ModelSelector class="model-dropdown" />
                </RadzenStack>

                <RadzenStack Orientation="Orientation.Horizontal" Gap="4px" JustifyContent="JustifyContent.End" AlignItems="AlignItems.Center">
                    <RadzenButton Icon="gavel" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Size="ButtonSize.Small" Click="@OpenRulesAsync" Title="@SharedResource.OpenRules" />
                    <RadzenButton Icon="extension" ButtonStyle="ButtonStyle.Base" Variant="Variant.Text" Size="ButtonSize.Small" Click="@OpenSkillsAsync" Title="@SharedResource.OpenSkills" />

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" JustifyContent="JustifyContent.End" AlignItems="AlignItems.Center">
                        <RadzenButton Icon="send"
                                      ButtonStyle="ButtonStyle.Base"
                                      Variant="Variant.Text"
                                      Visible="@(!IsLoading)"
                                      Disabled="@(!CanSend())"
                                      Click="@OnSendClick"
                                      title="@SharedResource.SendMessage"
                                      class="rz-chat-send-btn" />
                        <RadzenButton Icon="cancel"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Variant="Variant.Text"
                                      Visible="@IsLoading"
                                      Click="@Cancel.InvokeAsync"
                                      title="@SharedResource.Cancel"
                                      class="rz-chat-cancel-btn" />
                    </RadzenStack>
                </RadzenStack>
            </RadzenStack>
        </div>
    </div>

    @* Всплывающее меню с файлами *@
    @if (_filteredFiles.Any())
    {
        <div class="hints-menu">
            <ul class="hints-list">
                @for (var i = 0; i < _filteredFiles.Count; i++)
                {
                    var index = i;
                    var file = _filteredFiles[i];
                    var isSelected = index == _selectedIndex;
                    var fileName = Path.GetFileName(file.Replace('\\', '/'));
                    var fileDir = Path.GetDirectoryName(file.Replace('\\', '/')) ?? "";
                    var icon = GetFileIcon(fileName);
                    <li class="hint-item @(isSelected ? "selected" : "")"
                        @onclick="() => AddFileTokenAsync(file)">
                        <span class="file-icon">@icon</span>
                        <span class="file-name">@fileName</span>
                        <span class="file-path">@fileDir</span>
                    </li>
                }
            </ul>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<string> SendMessage { get; set; }
    [Parameter] public EventCallback<string> Cancel { get; set; }
    [Parameter] public bool IsLoading { get; set; }

    [Inject] private IChatService ChatService { get; set; } = null!;
    [Inject] private IVsCodeContextService VsCodeContextService { get; set; } = null!;
    [Inject] private IJSRuntime JsRuntime { get; set; } = null!;
    [Inject] private IVsBridge VsBridge { get; set; } = null!;
    [Inject] private ICommonSettingsProvider CommonSettingsProvider { get; set; } = null!;

    private ElementReference _textareaRef;
    private readonly List<InputToken> _tokens = [];
    private string _currentInput = string.Empty;
    private List<string> _filteredFiles = [];
    private int _selectedIndex;
    private bool _shouldPreventDefault;

    private List<AppMode> AppModeValues { get; } = [.. Enum.GetValues<AppMode>()];

    private string ModePlaceholder => ChatService.Session.Mode switch
    {
        AppMode.Plan => SharedResource.InputPlaceholderPlan,
        AppMode.Agent => SharedResource.InputPlaceholderAgent,
        _ => SharedResource.InputPlaceholder
    };

    private bool CanSend()
    {
        return !IsLoading && (!string.IsNullOrWhiteSpace(_currentInput) || _tokens.Any());
    }

    private async Task HandleInputAsync(ChangeEventArgs e)
    {
        _currentInput = e.Value?.ToString() ?? string.Empty;

        // Проверяем, есть ли @ в конце
        if (_currentInput.EndsWith(" @"))
        {
            // Показываем все файлы
            var source = VsCodeContextService.CurrentContext?.SolutionFiles ??
                         ["test1.cs", "C:\\asdtes\\t2aksjhdgj\\ahsghd hjagshjdg\\ajhsgdahjkg.cs"];
            _filteredFiles = source.Where(f => f.StartsWith(VsCodeContext.FilePrefix)).Take(10).ToList();
            _selectedIndex = 0;
        }
        else if (_currentInput.Contains('@'))
        {
            // Ищем текст после последнего @
            var lastAtIndex = _currentInput.LastIndexOf('@');
            var query = _currentInput.Substring(lastAtIndex + 1);

            var source = VsCodeContextService.CurrentContext?.SolutionFiles ??
                         ["test1.cs", "C:\\asdtes\\t2aksjhdgj\\ahsghd hjagshjdg\\ajhsgdahjkg.cs"];

            _filteredFiles = source
                .Where(f => f.StartsWith(VsCodeContext.FilePrefix) && f.Contains(query, StringComparison.OrdinalIgnoreCase))
                .Take(10)
                .ToList();
            _selectedIndex = 0;
        }
        else
        {
            _filteredFiles.Clear();
        }
    }

    private async Task AddFileTokenAsync(string filePath)
    {
        filePath = filePath.TrimStart(VsCodeContext.FilePrefix.ToCharArray());
        var fileName = Path.GetFileName(filePath.Replace('\\', '/'));

        // Удаляем @ и текст после него из currentInput
        var lastAtIndex = _currentInput.LastIndexOf('@');
        if (lastAtIndex >= 0)
        {
            _currentInput = _currentInput.Substring(0, lastAtIndex);
        }

        // Добавляем токен файла
        _tokens.Add(new FileToken
        {
            FilePath = filePath,
            FileName = fileName
        });

        _filteredFiles.Clear();
        _selectedIndex = 0;

        // Фокус обратно на input
        await FocusInputAsync();
    }

    private async Task RemoveTokenAsync(FileToken token)
    {
        _tokens.Remove(token);
        await FocusInputAsync();
    }

    private async Task FocusInputAsync()
    {
        try
        {
            await _textareaRef.FocusAsync();
        }
        catch
        {
            // ignored
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (_filteredFiles.Any())
        {
            switch (e.Key)
            {
                case "ArrowDown":
                    _selectedIndex = (_selectedIndex + 1) % _filteredFiles.Count;
                    _shouldPreventDefault = true;
                    return;
                case "ArrowUp":
                    _selectedIndex = (_selectedIndex - 1 + _filteredFiles.Count) % _filteredFiles.Count;
                    _shouldPreventDefault = true;
                    return;
                case "Tab":
                case "Enter":
                    {
                        _shouldPreventDefault = true;
                        if (_selectedIndex >= 0 && _selectedIndex < _filteredFiles.Count)
                        {
                            await AddFileTokenAsync(_filteredFiles[_selectedIndex]);
                        }
                        return;
                    }
                case "Escape":
                    _shouldPreventDefault = true;
                    _filteredFiles.Clear();
                    return;
            }
        }

        // Enter без Shift/Ctrl — отправка
        if (e is { Key: "Enter", CtrlKey: false, ShiftKey: false } && !_filteredFiles.Any())
        {
            _shouldPreventDefault = true;
            await OnSendClick();
        }
        else
        {
            _shouldPreventDefault = false;
        }
    }

    private async Task OnSendClick()
    {
        if (!CanSend()) return;

        // Загружаем содержимое файлов перед отправкой
        var fileIndex = 0;
        foreach (var fileToken in _tokens.OfType<FileToken>())
        {
            if (string.IsNullOrEmpty(fileToken.FileContent))
            {
                var readFileTool = await VsBridge.ExecuteToolAsync(
                    BuiltInToolEnum.ReadFiles,
                    new Dictionary<string, object> { { $"file{++fileIndex}", new ReadFileParams { Name = fileToken.FilePath } } });

                fileToken.FileContent = readFileTool.Result;
            }
        }

        // Формируем сообщение для отправки
        var messageBuilder = new StringBuilder();

        // Добавляем текущий ввод
        if (!string.IsNullOrWhiteSpace(_currentInput))
        {
            messageBuilder.AppendLine(_currentInput.Trim());
        }

        // Добавляем файлы с их содержимым
        foreach (var fileToken in _tokens.OfType<FileToken>())
        {
            messageBuilder.Append(fileToken.FileContent);
        }

        var message = messageBuilder.ToString();

        // Очищаем состояние
        _currentInput = string.Empty;
        _tokens.Clear();
        _filteredFiles.Clear();

        await SendMessage.InvokeAsync(message);
    }

    private string GetFileIcon(string fileName)
    {
        var extension = Path.GetExtension(fileName.Replace('\\', '/')).ToLowerInvariant();
        return extension switch
        {
            ".cs" => "📄",
            ".razor" => "⚡",
            ".html" => "🌐",
            ".css" => "🎨",
            ".js" => "📜",
            ".json" => "📋",
            ".xml" => "📋",
            ".txt" => "📝",
            ".md" => "📖",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".svg" => "🖼️",
            ".dll" or ".exe" => "⚙️",
            ".config" => "🔧",
            ".csproj" or ".sln" => "📦",
            _ => "📄"
        };
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ChatService.SessionChanged += HandlePropertyChanged;
        CommonSettingsProvider.Current.PropertyChanged += HandlePropertyChanged;
    }

    private void HandlePropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName is nameof(UIBlazor.Models.ConversationSession.Mode)
            or nameof(UIBlazor.Models.ConversationSession)
            or nameof(CommonOptions.SendCurrentFile)
            or nameof(CommonOptions.SendSolutionsStricture))
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenRulesAsync()
    {
        await VsBridge.ExecuteToolAsync(BasicEnum.OpenFile, new Dictionary<string, object> { { "param1", ".agents/rules.md" } });
    }

    private async Task OpenSkillsAsync()
    {
        await VsBridge.ExecuteToolAsync(BasicEnum.OpenFolder, new Dictionary<string, object> { { "param1", ".agents/skills/" } });
    }

    public void Dispose()
    {
        ChatService.SessionChanged -= HandlePropertyChanged;
        CommonSettingsProvider.Current.PropertyChanged -= HandlePropertyChanged;
    }

    private void OnModeChanged()
    {
        _ = ChatService.SaveSessionAsync();
    }
}
