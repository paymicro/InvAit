@inherits RadzenComponent

<div class="chat-container" >
    <div id="@Id" contenteditable="true" class="custom-editor" @oninput="HandleInput" @onkeydown="OnKeyDown" @onkeydown:preventDefault="@shouldPreventDefault" @onblur="SaveSelection"></div>

    @if (filteredFiles.Any())
    {
        <div class="hints-menu" style="top: @(cursorCoords.Top)px; left: @(cursorCoords.Left)px;">
            <ul class="hints-list">
                @for (int i = 0; i < filteredFiles.Count; i++)
                {
                    var index = i;
                    var file = filteredFiles[i];
                    var isSelected = index == selectedIndex;
                    <li class="hint-item @(isSelected ? "selected" : "")" 
                        @onclick="() => AddChip(file)">
                        @file
                    </li>
                }
            </ul>
        </div>
    }

    @* Кнопки *@
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Right">
        <RadzenDropDown TValue="AppMode" class="mode-dropdown" Data="@AppModeValues" @bind-Value="@CurrentMode" />

        <RadzenButton Icon="send"
                      ButtonStyle="ButtonStyle.Primary"
                      Variant="Variant.Text"
                      Visible="@(!IsLoading)"
                      Disabled="@(string.IsNullOrWhiteSpace(message) || IsLoading)"
                      Click="@OnSendClick"
                      Title="Send message"
                      class="rz-chat-send-btn" />
        <RadzenButton Icon="dangerous"
                      ButtonStyle="ButtonStyle.Danger"
                      Variant="Variant.Text"
                      Visible="@IsLoading"
                      Click="@Cancel.InvokeAsync"
                      Title="Cancel"
                      class="rz-chat-cancel-btn" />
    </RadzenStack>
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public EventCallback<string> SendMessage { get; set; }

    [Parameter] public EventCallback<string> Cancel { get; set; }

    [Parameter] public string Placeholder { get; set; } = string.Empty;

    [Parameter] public bool IsLoading { get; set; }

    [Inject] private ChatService ChatService { get; set; } = null!;

    [Inject] IJSRuntime JS { get; set; } = null!;

    [Inject] IVsCodeContextService VsCodeContextService { get; set; } = null!;

    private string Id = "editor_" + Guid.NewGuid();

    private List<AppMode> AppModeValues { get; } = [.. Enum.GetValues<AppMode>()];

    private AppMode CurrentMode
    {
        get => ChatService.Session?.Mode ?? AppMode.Chat; // ?? - т.к. Session не успевает подгрузиться в первый раз
        set => ChatService.Session.Mode = value; // TODO сохранение
    }

    private bool shouldPreventDefault;

    public string message { get; set; } = string.Empty;

    // Класс для координат
    public class Coords { public int Top { get; set; } = 0; public int Left { get; set; } = 0; }
    private Coords cursorCoords = new();

    private List<string> filteredFiles = new();
    private int selectedIndex = 0;

    private int lastMatchLength = 0; // Сколько символов (включая @) нужно удалить

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // запрет вставки картинок и стилей из буффера
            await JS.InvokeVoidAsync("editorFunctions.setupPasteInterop", Id);
        }
    }

    private async Task SaveSelection()
    {
        // Вызываем сохранение range в JS
        await JS.InvokeVoidAsync("editorFunctions.saveSelection");
    }

    private async Task HandleInput()
    {
        cursorCoords = await JS.InvokeAsync<Coords>("editorFunctions.getCursorCoordinates", Id);
        var result = await JS.InvokeAsync<JsonElement?>("editorFunctions.getWordBeforeCursor");

        if (result != null)
        {
            string query = result.Value.GetProperty("query").GetString() ?? string.Empty;
            lastMatchLength = result.Value.GetProperty("length").GetInt32();

            var source = VsCodeContextService.CurrentContext?.SolutionFiles ?? ["test1.cs", "test2.cs"];

            filteredFiles = source
                .Where(u => u.Contains(query, StringComparison.OrdinalIgnoreCase))
                .Take(10)
                .ToList();
            selectedIndex = 0;
        }
        else
        {
            filteredFiles.Clear();
        }

        message = await JS.InvokeAsync<string>("editorFunctions.getText", Id);
    }

    private async Task AddChip(string value)
    {
        // Создаем HTML чипса
        string chipHtml = $"<span contenteditable='false' class='chip'> @{value} </span>";

        // Передаем lastMatchLength, чтобы JS удалил "@набранное_имя" перед вставкой
        await JS.InvokeVoidAsync("editorFunctions.insertChip", Id, chipHtml, lastMatchLength);

        filteredFiles.Clear();
        lastMatchLength = 0;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (filteredFiles.Any())
        {
            if (e.Key == "ArrowDown")
            {
                selectedIndex = (selectedIndex + 1) % filteredFiles.Count;
                shouldPreventDefault = true;
                return;
            }
            if (e.Key == "ArrowUp")
            {
                selectedIndex = (selectedIndex - 1 + filteredFiles.Count) % filteredFiles.Count;
                shouldPreventDefault = true;
                return;
            }
            if (e.Key == "Tab" || e.Key == "Enter")
            {
                shouldPreventDefault = true;
                if (selectedIndex >= 0 && selectedIndex < filteredFiles.Count)
                {
                    await AddChip(filteredFiles[selectedIndex]);
                }
                return;
            }
            if (e.Key == "Escape")
            {
                shouldPreventDefault = true;
                filteredFiles.Clear();
                return;
            }
        }

        // Enter без Shift/Ctrl — отправка
        if (e is { Key: "Enter", CtrlKey: false, ShiftKey: false })
        {
            shouldPreventDefault = true;
            // Здесь можно добавить проверку, не открыто ли сейчас меню подсказок
            await Task.WhenAll(SendMessage.InvokeAsync(message));
        }
        else
        {
            shouldPreventDefault = false;
        }
    }

    private Task OnSendClick() => SendMessage.InvokeAsync(message);
}
