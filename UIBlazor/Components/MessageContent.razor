<div class="ai-chat-message">
    @if (Message.Role != ChatMessageRole.Assistant)
    {
        <MarkdownBlock Content="@Message.Content" />
    }
    else
    {
        toolCount = 0;
        @if (!string.IsNullOrEmpty(Message.ReasoningContent))
        {
            <Details Text="@SharedResource.Thinking" Icon="fa-solid fa-lightbulb" class="reasoning-details">
                <MarkdownBlock Content="@Message.ReasoningContent" />
            </Details>
        }

        @foreach (var segment in Message.Segments)
        {
            if (segment.Type == SegmentType.Tool)
            {
                <ToolCallBlock @key="segment.Id"
                    Segment="@segment"
                    OnApproval="@OnToolApprovalHandler"
                    ToolResult="@(toolCount < Message.ToolResults.Count ? Message.ToolResults[toolCount] : null)" />
                toolCount++;
            }
            else if (segment.Type is SegmentType.Markdown)
            {
                <MarkdownBlock @key="segment.Id" Content="@segment.CurrentLine.ToString()" />
            }
        }
    }
</div>

@code {
    [Parameter] public VisualChatMessage Message { get; set; } = new();
    [Parameter] public EventCallback<(string MessageId, string SegmentId, bool Approved)> OnToolApproval { get; set; }
    [Inject] private IToolManager ToolManager { get; set; } = null!;

    private int toolCount;

    private async Task OnToolApprovalHandler((string SegmentId, bool Approved) args)
    {
        await OnToolApproval.InvokeAsync((Message.Id, args.SegmentId, args.Approved));
    }
}