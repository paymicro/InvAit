@using System.IO
@using System.Text

<div class="diff-view">
    @if (!string.IsNullOrEmpty(FilePath))
    {
        <div @key="@FilePath" class="tool-file-header">@FilePath</div>
    }

    <div class="diff-block">
        <Virtualize Items="@_blocks" Context="block" ItemSize="16" >@* Обязательно все элементы 16px *@
            <DiffLine Model="block" />
        </Virtualize>
    </div>
</div>

@code {
    [Parameter] public List<string> Lines { get; set; } = [];

    private string? FilePath { get; set; }
    private List<DiffBlock> _blocks = [];

    protected override void OnParametersSet()
    {
        ParseDiff();
    }

    private void ParseDiff()
    {
        bool inSearch = false;
        bool inReplace = false;
        int blockIndex = 0;

        // Читаем первую строку для FilePath
        FilePath = Lines[0];
        foreach (var line in Lines)
        {
            UpdateOrAddBlock(blockIndex++, line, ref inSearch, ref inReplace);
        }

        // Удаляем лишние блоки, если текст сократился
        if (_blocks.Count > blockIndex)
            _blocks.RemoveRange(blockIndex, _blocks.Count - blockIndex);
    }

    private void UpdateOrAddBlock(int index, string line, ref bool inSearch, ref bool inReplace)
    {
        var type = DetermineType(line, ref inSearch, ref inReplace);

        if (index < _blocks.Count)
        {
            // ВАЖНО: Обновляем свойства существующего объекта.
            // Blazor увидит, что экземпляр тот же, и проверит только Content.
            var block = _blocks[index];
            if (block.Type != type || block.Content.Length < line.Length)
            {
                block.Type = type;
                block.Content = line;
            }
        }
        else
        {
            _blocks.Add(new DiffBlock { Type = type, Content = line });
        }
    }

    private DiffBlockType DetermineType(string line, ref bool inSearch, ref bool inReplace)
    {
        var trimmed = line.Trim();

        if (trimmed.StartsWith("<<<<<<< SEARCH"))
        {
            inSearch = true;
            inReplace = false; // Сброс на всякий случай
            return DiffBlockType.SearchHeader;
        }
        if (trimmed.StartsWith("======="))
        {
            inSearch = false;
            inReplace = true;
            return DiffBlockType.Separator;
        }
        if (trimmed.StartsWith(">>>>>>> REPLACE"))
        {
            inSearch = false;
            inReplace = false;
            return DiffBlockType.ReplaceHeader;
        }

        if (inSearch) return DiffBlockType.Removed;
        if (inReplace) return DiffBlockType.Added;

        return DiffBlockType.Context;
    }

    public enum DiffBlockType
    {
        SearchHeader,
        Separator,
        ReplaceHeader,
        Removed,
        Added,
        Context
    }

    public class DiffBlock
    {
        public DiffBlockType Type { get; set; }
        public string Content { get; set; } = string.Empty;
    }
}
