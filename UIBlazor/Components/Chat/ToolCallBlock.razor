@using UIBlazor.Services.Settings
@using UIBlazor.Models
@using Shared.Contracts
@inject IToolManager ToolManager

<div class="tool-call-block" data-tool="@Segment.ToolName">
    <div class="tool-call-header @statusClass">
        @SharedResource.CallingTool: <strong>@DisplayName</strong>@(Segment.IsClosed ? "" : " ...")
    </div>

    @if (Segment.Lines.Count > 0)
    {
        if (Segment.ToolName == BuiltInToolEnum.CreateFile)
        {
            @* TODO: Нужен отдельный компонент, который будет ставить charp в зависимости от расширения файла в первой строке  *@
            <div class="tool-call-args">
                <span>@Segment.Lines[0..]</span>
            </div>
            <MarkdownBlock Content="@string.Join("\n", Segment.Lines[1..].Prepend("```csharp").Append("```"))" />
        }
        else
        {
            <div class="tool-call-args">
                @if (Segment.ToolName == BuiltInToolEnum.ApplyDiff)
                {
                    <DiffView Lines="@Segment.Lines" />
                }
                else
                {
                    <pre>@string.Join("\n", Segment.Lines[0..])</pre>
                }
            </div>
        }
    }

    @if (Segment.IsClosed)
    {
        <div class="tool-approval-footer @statusClass">
            @if (Segment.ApprovalStatus == ToolApprovalStatus.Pending)
            {
                <div class="tool-approval-label"><i class="rz-icon-notification rz-ml-2"></i>@SharedResource.ApproveRequired</div>
                <div class="tool-approval-actions">
                    <RadzenButton Icon="check" class="tool-approve-btn rz-m-2" Click="@(async () => await OnApproval.InvokeAsync((Segment.Id, true)))" />
                    <RadzenButton Icon="close" class="tool-reject-btn rz-m-2" Click="@(async () => await OnApproval.InvokeAsync((Segment.Id, false)))" />
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public ContentSegment Segment { get; set; } = null!;
    [Parameter] public EventCallback<(string SegmentId, bool Approved)> OnApproval { get; set; }

    private string DisplayName => ToolManager.GetTool(Segment.ToolName)?.DisplayName ?? Segment.ToolName;

    string statusClass => Segment.ApprovalStatus switch
    {
        ToolApprovalStatus.Approved => "approved",
        ToolApprovalStatus.Rejected => "rejected",
        _ => "pending" // класс по умолчанию
    };
}
