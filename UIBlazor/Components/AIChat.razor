@using UIBlazor.Models
@using UIBlazor.Services
@inherits RadzenComponent

@inject ChatService ChatService
@inject DialogService DialogService
@inject IJSRuntime JS

<div @ref="@Element" @attributes="Attributes" class="@GetCssClass()" style="@Style" id="@GetId()" >
    <!-- Chat Header -->
    <RadzenStack class="rz-chat-header" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <span class="rz-chat-header-title">@Title</span>
        }
        <RadzenAppearanceToggle Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" />

        <RadzenStack class="rz-chat-header-actions" Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.5rem">
            <RadzenButton Icon="delete_history" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@OnClearChatAsync" Title="Clear chat history" class="rz-chat-header-clear" />
            <RadzenButton Icon="settings" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base"
                            Click="@OnShowSettingsAsync" Title="Settings" class="rz-chat-header-settings" />
            <RadzenButton Icon="favorite" Click="@OnTestAsync" Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" />
        </RadzenStack>
    </RadzenStack>

    <!-- Chat Messages -->
    <div class="rz-chat-messages" @ref="_messagesContainer">
        @if (Messages.Count == 0)
        {
            if (EmptyTemplate != null)
            {
                @EmptyTemplate
            }
            else
            {
                <RadzenStack class="rz-chat-empty" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem">
                    <RadzenIcon Icon="chat_bubble_outline" class="rz-text-secondary-color" />
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mt-2 rz-text-tertiary-color">@EmptyMessage</RadzenText>
                </RadzenStack>
            }
        }
        else
        {
            @foreach (var message in Messages)
            {
                if (MessageTemplate != null)
                {
                    @MessageTemplate(message)    
                }
                else
                {
                    var isUser = message.Role == ChatMessageRole.User;
                <div class="rz-chat-message rz-chat-message-@message.Role" @key="message.Id">
                    <RadzenStack class="rz-chat-message-avatar" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0">
                        <span class="rz-chat-avatar-initials" >
                            @if (message.Role == ChatMessageRole.User)
                            {
                                @UserAvatarText
                            }
                            else if (message.Role == ChatMessageRole.Assistant)
                            {
                                <RadzenIcon Icon="robot_2" IconStyle="IconStyle.Info" />
                            }
                            else if (message.Role == ChatMessageRole.Tool)
                            {
                                <RadzenIcon Icon="design_services" />
                            }
                        </span>
                    </RadzenStack>
                    <RadzenStack Orientation="Orientation.Vertical" AlignItems="@(isUser ? AlignItems.End : AlignItems.Start)" Gap="0.25rem" class="rz-chat-message-content">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="@(isUser ? JustifyContent.End : JustifyContent.Start)" Gap="0.5rem" class="rz-chat-message-info">
                            <div class="rz-chat-message-time">
                                @message.Timestamp.ToString("HH:mm")
                            </div>
                        </RadzenStack>
                        <div class="rz-chat-message-text">
                            @if (message.IsStreaming)
                            {
                                if (!string.IsNullOrEmpty(message.ReasoningContent))
                                {
                                    <details>
                                    <summary>Поток сознания...</summary>@message.ReasoningContent</details>
                                }
                                @message.Content <RadzenIcon Icon="more_horiz" class="rz-chat-message-streaming-icon" />
                            }
                            else
                            {
                                if (message.Role == ChatMessageRole.Tool)
                                {
                                    @message.Content
                                }
                                else
                                {
                                    if (!string.IsNullOrEmpty(message.ReasoningContent))
                                    {
                                        <details>
                                        <summary>Мыслишки</summary>@message.ReasoningContent</details>
                                    }
                                    <RadzenMarkdown Text=@message.Content />
                                }
                            }
                        </div>
                    </RadzenStack>
                </div>
                }
            }
        }
    </div>

    <!-- Chat Input -->
    <div class="rz-chat-input">
        <div class="rz-chat-input-inner">
            <textarea @ref="_inputElement" 
                        value="@CurrentInput"
                        @oninput="OnInputAsync" 
                        @onkeydown="OnKeyDownAsync" 
                        @onkeydown:preventDefault="_preventDefault"
                        class="rz-textarea rz-chat-textarea"
                        placeholder="@Placeholder"
                        disabled="@Disabled"
                        readonly="@ReadOnly"
                        rows="1"
                        @attributes="@InputAttributes"></textarea>
                <RadzenButton Icon="send"
                            ButtonStyle="ButtonStyle.Primary" 
                            Variant="Variant.Text"
                            Visible="@(!IsLoading)"
                            Disabled="@(string.IsNullOrWhiteSpace(CurrentInput) || IsLoading || Disabled)"
                            Click="@OnSendMessageAsync"
                            Title="Send message"
                            class="rz-chat-send-btn" />
                <RadzenButton Icon="dangerous"
                            ButtonStyle="ButtonStyle.Danger"
                            Variant="Variant.Text"
                            Visible="@IsLoading"
                            Click="@CancelResponceAsync"
                            Title="Cancel"
                            class="rz-chat-cancel-btn" />
        </div>
    </div>
</div>
