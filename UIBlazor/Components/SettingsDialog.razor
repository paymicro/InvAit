@using Shared.Contracts.Mcp
@inherits RadzenComponent

<RadzenTabs RenderMode="TabRenderMode.Client" class="settings">
    <Tabs>
        <RadzenTabsItem Text="@SharedResource.SettingsGeneral">
            <RadzenStack Gap="1rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.Subtitle1">@SharedResource.Profile:</RadzenText>
                    <RadzenDropDown Data="@ProfileManager.Current.Profiles" TextProperty="Name" ValueProperty="Id"
                                    @bind-Value="@ProfileManager.Current.ActiveProfileId"
                                    Style="flex: 1;" />
                    <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat" Click="@OnAddProfile" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="@OnDeleteProfile"
                                  Disabled="@(ProfileManager.Current.Profiles.Count <= 1)" />
                </RadzenStack>

                <RadzenStack Gap="1rem">
                    <RadzenFormField Text="@SharedResource.ProfileName" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="@ProfileManager.ActiveProfile.Name" Immediate Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenFormField Text="@SharedResource.Provider" Variant="Variant.Outlined">
                        <RadzenDropDown @bind-Value="@ProfileManager.ActiveProfile.Provider" Data="@_providers" Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenFormField Text="@SharedResource.Endpoint" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="@ProfileManager.ActiveProfile.Endpoint" Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenFormField Text="ApiKey" Variant="Variant.Outlined">
                        <RadzenPassword @bind-Value="@ProfileManager.ActiveProfile.ApiKey" Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenDropDown TValue="string"
                                        Data="@ProfileManager.ActiveProfile.AvailableModels"
                                        @bind-Value="@ProfileManager.ActiveProfile.Model"
                                        Placeholder="@SharedResource.SelectModel"
                                        AllowCustomText="true"
                                        Style="width: 100%" />
                        <RadzenButton Icon="autorenew" Click="() => UpdateModelsAsync(CancellationToken.None)" ButtonStyle="ButtonStyle.Light" />
                    </RadzenStack>

                    <CheckBox Text="@SharedResource.UseStream" @bind-Value=@ProfileManager.ActiveProfile.Stream />
                    <CheckBox Text="@SharedResource.SkipSSL" @bind-Value=@ProfileManager.ActiveProfile.SkipSSL />

                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="@SharedResource.Temperature" />
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenSlider @bind-Value="@ProfileManager.ActiveProfile.Temperature" Min="0" Max="2" Step="0.1" Style="width: 100%; height: 20px;" />
                            <RadzenLabel Text="@Math.Abs(ProfileManager.ActiveProfile.Temperature).ToString("0.0")" Style="text-align: right; width: 50px;" />
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="@SharedResource.MaxTokens" />
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenSlider @bind-Value="@ProfileManager.ActiveProfile.MaxTokens" Min=1000 Max=256000 Step="1000" Style="width: 100%; height: 20px;" />
                            <RadzenLabel Text="@($"{ProfileManager.ActiveProfile.MaxTokens / 1000}K")" Style="text-align: right; width: 50px;" />
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenFormField Text="@SharedResource.SystemPrompt" Variant="Variant.Outlined">
                        <RadzenTextArea @bind-Value="@ProfileManager.ActiveProfile.SystemPrompt" Style="min-height: 90px" />
                    </RadzenFormField>
                </RadzenStack>

                <RadzenStack Gap="0.2rem">
                    <RadzenLabel Text="@SharedResource.MaxRetries" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenSlider @bind-Value="@CommonSettingsProvider.Current.MaxRetries" Min="0" Max="50" Step="1" Style="width: 100%; height: 20px;" />
                        <RadzenLabel Text="@CommonSettingsProvider.Current.MaxRetries.ToString()" Style="text-align: right; width: 50px;" />
                    </RadzenStack>
                </RadzenStack>

                <CheckBox Text="@SharedResource.SendCurrentFile" @bind-Value="@CommonSettingsProvider.Current.SendCurrentFile" />
                <CheckBox Text="@SharedResource.SendSolutionsStricture" @bind-Value="@CommonSettingsProvider.Current.SendSolutionsStricture" />
            </RadzenStack>
        </RadzenTabsItem>
        <RadzenTabsItem Text="@SharedResource.SettingsTools">
            <RadzenStack Gap="1rem">
                @foreach (var category in _toolCategories)
                {
                    var state = ToolManager.Current.CategoryStates.ContainsKey(category)
                    ? ToolManager.Current.CategoryStates[category]
                    : new ToolCategorySettings();

                    <RadzenStack Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                            <CheckBox Text="@GetCategoryName(category)" @bind-Value="@state.IsEnabled" @bind-Value:after="() => OnCategorySettingChanged(category, state)" />
                            <RadzenDropDown TValue="ToolApprovalMode" Data="@(Enum.GetValues<ToolApprovalMode>())"
                                            @bind-Value="@state.ApprovalMode" @bind-Value:after="() => OnCategorySettingChanged(category, state)" />
                        </RadzenStack>

                        <div class="@(state.IsEnabled ? "category-tools-visible" : "category-tools-hidden")">
                            @if (state.IsEnabled)
                            {
                                var categoryTools = ToolManager.GetAllTools().Where(t => t.Category == category).ToList();
                                if (categoryTools.Count > 1)
                                {
                                    <RadzenAccordion>
                                        <Items>
                                            <RadzenAccordionItem Text="@SharedResource.Tools" Icon="build">
                                                <RadzenStack Gap="0.5rem">
                                                    @foreach (var tool in categoryTools)
                                                    {
                                                        <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
                                                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                                <RadzenCheckBox @bind-Value="@tool.Enabled" @bind-Value:after="() => OnToolSettingChanged(tool)" Name="@($"tool_{tool.Name}")" />
                                                                <RadzenLabel Text="@tool.Name" Component="@($"tool_{tool.Name}")" Style="font-size: 0.9rem; opacity: 0.8;" />
                                                            </RadzenStack>
                                                            <RadzenText TextStyle="TextStyle.Caption" class="tool-description">@tool.Description</RadzenText>
                                                        </RadzenStack>
                                                    }
                                                </RadzenStack>
                                            </RadzenAccordionItem>
                                        </Items>
                                    </RadzenAccordion>
                                }
                            }
                        </div>
                    </RadzenStack>
                }
            </RadzenStack>
        </RadzenTabsItem>

        <RadzenTabsItem Text="MCP">
            <RadzenStack Gap="0.5rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <CheckBox Text="Enable MCP" @bind-Value="@McpSettingsProvider.Current.Enabled" @bind-Value:after="OnMcpEnabledChanged" />
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem" JustifyContent="JustifyContent.End">
                        <RadzenButton Icon="edit_note" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Click="@OnOpenMcpSettings" />
                        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@OnReloadMcpSettings" />
                    </RadzenStack>
                </RadzenStack>

                @if (McpSettingsProvider.Current.Enabled)
                {
                    @if (!McpSettingsProvider.Current.Servers.Any())
                    {
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); font-style: italic;">
                            @SharedResource.NoMCP
                        </RadzenText>
                    }

                    @foreach (var server in McpSettingsProvider.Current.Servers)
                    {
                        var hasError = McpSettingsProvider.Current.ServerErrors.TryGetValue(server.Name, out var errorMsg);
                        var borderColor = hasError ? "var(--rz-error-color)" : "var(--rz-border-color)";
                        var serverStyle = $"padding: 0.5rem; border: 1px solid {borderColor}; border-radius: var(--rz-border-radius);";

                        <RadzenStack Gap="0.5rem" Style="@serverStyle">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                    <CheckBox Text="@server.Name" @bind-Value="@server.Enabled" @bind-Value:after="OnMcpToolSettingChanged" />
                                    <RadzenBadge Text="@server.Transport" Style="font-size: 0.7rem;" />
                                    @if (hasError)
                                    {
                                        <RadzenBadge Text="@SharedResource.Error" Style="font-size: 0.7rem; background: var(--rz-error-color);" />
                                    }
                                    else if (server.Enabled && server.Tools.Any())
                                    {
                                        <RadzenBadge Text="@SharedResource.Ready" Style="font-size: 0.7rem; background: var(--rz-success-color);" />
                                    }
                                </RadzenStack>
                                <RadzenDropDown TValue="ToolApprovalMode" Data="@(Enum.GetValues<ToolApprovalMode>())"
                                                Value="@GetMcpServerApprovalMode(server)"
                                                ValueChanged="@(mode => OnMcpServerApprovalChanged(server, mode))"
                                                Style="width: 150px; flex-shrink: 0;" />
                            </RadzenStack>

                            @if (hasError && !string.IsNullOrEmpty(errorMsg))
                            {
                                <RadzenStack Style="padding: 0.5rem; background: var(--rz-error-background); border-radius: var(--rz-border-radius); font-size: 0.8rem; color: var(--rz-error-color);">
                                    <strong>Error:</strong> @errorMsg
                                </RadzenStack>
                            }

                            <RadzenStack Gap="0.2rem" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color); padding-left: 2rem;">
                                @if (server.Transport == "stdio")
                                {
                                    <div>Command: @server.Command @(string.Join(" ", server.Args))</div>
                                }
                                else
                                {
                                    <div>URL: @server.Url</div>
                                }
                                @if (server.Env.Any())
                                {
                                    <div>Env: @server.Env.Count variable(s)</div>
                                }
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.3rem" Style="padding-left: 2rem;">
                                <RadzenButton Text="@SharedResource.RefreshTools" Icon="sync" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => OnRefreshMcpTools(server))" IsBusy="@(_refreshingServerId == server.Name)" />
                            </RadzenStack>

                            @if (server.Tools.Any())
                            {
                                <RadzenAccordion Style="margin-top: 0.3rem; border: none;">
                                    <Items>
                                        <RadzenAccordionItem Text="@SharedResource.Tools" Icon="build">
                                            <RadzenStack Gap="0.5rem">
                                                @foreach (var tool in server.Tools)
                                                {
                                                    <RadzenStack Orientation="Orientation.Vertical" JustifyContent="JustifyContent.SpaceBetween">
                                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                                            <RadzenCheckBox @bind-Value="@tool.Enabled" @bind-Value:after="OnMcpToolSettingChanged" Name="@($"mcp__{server.Name}__{tool.Name}")" />
                                                            <RadzenLabel Text="@tool.Name" Component="@($"mcp__{server.Name}__{tool.Name}")" />
                                                        </RadzenStack>
                                                        <RadzenText TextStyle="TextStyle.Caption" class="tool-description">@tool.Description</RadzenText>
                                                    </RadzenStack>
                                                }
                                            </RadzenStack>
                                        </RadzenAccordionItem>
                                    </Items>
                                </RadzenAccordion>
                            }
                        </RadzenStack>
                    }
                }
            </RadzenStack>
        </RadzenTabsItem>
        <RadzenTabsItem Text="UI">
            <LanguageSelector />
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code
{
    [Inject] ChatService ChatService { get; set; } = null!;
    [Inject] NotificationService NotificationService { get; set; } = null!;
    [Inject] IToolManager ToolManager { get; set; } = null!;
    [Inject] IProfileManager ProfileManager { get; set; } = null!;
    [Inject] ICommonSettingsProvider CommonSettingsProvider { get; set; } = null!;
    [Inject] DialogService DialogService { get; set; } = null!;
    [Inject] IMcpSettingsProvider McpSettingsProvider { get; set; } = null!;

    private readonly ToolCategory[] _toolCategories = [
        ToolCategory.ReadFiles,
        ToolCategory.WriteFiles,
        ToolCategory.DeleteFiles,
        ToolCategory.ModeSwitch,
        ToolCategory.Execution
    ];
    private readonly string[] _providers = ["OpenAI Compatible"];

    private string? _refreshingServerId;

    private async Task OnMcpEnabledChanged()
    {
        if (!McpSettingsProvider.Current.Enabled)
        {
            await McpSettingsProvider.StopAllAsync();
        }
        await McpSettingsProvider.SaveAsync();
    }

    private async Task OnOpenMcpSettings()
    {
        await McpSettingsProvider.OpenSettingsFileAsync();
    }

    private async Task OnReloadMcpSettings()
    {
        await McpSettingsProvider.LoadMcpFileAsync();
        StateHasChanged();
    }

    private async Task OnRefreshMcpTools(McpServerConfig server)
    {
        _refreshingServerId = server.Name;
        StateHasChanged();

        var result = await McpSettingsProvider.RefreshToolsAsync(server);

        _refreshingServerId = null;

        // Update error state
        if (result.StartsWith("Success"))
        {
            McpSettingsProvider.Current.ServerErrors.Remove(server.Name);
        }
        else
        {
            McpSettingsProvider.Current.ServerErrors[server.Name] = result;
        }

        NotificationService.Notify(new NotificationMessage
        {
            Severity = result.StartsWith("Success") ? NotificationSeverity.Success : NotificationSeverity.Error,
            Summary = result,
            Duration = 4000
        });

        await McpSettingsProvider.SaveAsync();
        StateHasChanged();
    }

    private ToolApprovalMode GetMcpServerApprovalMode(McpServerConfig server)
    {
        return McpSettingsProvider.Current.ServerApprovalModes.TryGetValue(server.Name, out var mode)
            ? mode
            : ToolApprovalMode.AutoApprove;
    }

    private async Task OnMcpServerApprovalChanged(McpServerConfig server, ToolApprovalMode mode)
    {
        McpSettingsProvider.Current.ServerApprovalModes[server.Name] = mode;
        await McpSettingsProvider.SaveAsync();
    }

    private async Task OnAddProfile()
    {
        var newProfile = new ConnectionProfile();
        await ProfileManager.SaveProfileAsync(newProfile);
        await ProfileManager.ActivateProfileAsync(newProfile.Id);
    }

    private async Task OnDeleteProfile()
    {
        if (string.IsNullOrEmpty(ProfileManager.Current.ActiveProfileId))
        {
            return;
        }

        var confirm = await DialogService.Confirm($"{SharedResource.DeleteProfileQuestion} '{ProfileManager.ActiveProfile.Name}'?", SharedResource.DeleteProfile,
           new ConfirmOptions() { OkButtonText = SharedResource.Yes, CancelButtonText = SharedResource.No });

        if (confirm == true)
        {
            await ProfileManager.DeleteProfileAsync(ProfileManager.Current.ActiveProfileId);
        }
    }

    private async Task UpdateModelsAsync(CancellationToken cancellationToken)
    {
        try
        {
            var models = await ChatService.GetModelsAsync(cancellationToken);
            var list = models.Data.Select(m => m.Id).ToList();

            // TODO возможность добавлять кастомную строку
            ProfileManager.ActiveProfile.AvailableModels = list;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = SharedResource.ErrorModelsNotFound,
                Detail = ex.Message,
                Duration = 10_000,
                ShowProgress = true,
            });
        }
        StateHasChanged();
    }

    private string GetCategoryName(ToolCategory category)
    {
        return category switch
        {
            ToolCategory.ReadFiles => SharedResource.CategoryReadFiles,
            ToolCategory.WriteFiles => SharedResource.CategoryWriteFiles,
            ToolCategory.DeleteFiles => SharedResource.CategoryDeleteFiles,
            ToolCategory.ModeSwitch => SharedResource.CategoryModeSwitch,
            ToolCategory.Execution => SharedResource.CategoryExecution,
            _ => category.ToString()
        };
    }

    private async Task OnCategorySettingChanged(ToolCategory category, ToolCategorySettings state)
    {
        ToolManager.UpdateCategorySettings(category, state.IsEnabled, state.ApprovalMode);
        await Task.CompletedTask;
    }

    private async Task OnToolSettingChanged(Tool tool)
    {
        ToolManager.ToggleTool(tool.Name, tool.Enabled);
        await Task.CompletedTask;
    }

    private async Task OnMcpToolSettingChanged()
    {
        // Update server enabled states
        foreach (var server in McpSettingsProvider.Current.Servers)
        {
            McpSettingsProvider.Current.ServerEnabledStates[server.Name] = server.Enabled;
        }

        McpSettingsProvider.Current.ToolDisabledStates.Clear();
        foreach (var server in McpSettingsProvider.Current.Servers)
        {
            foreach (var tool in server.Tools)
            {
                var toolKey = $"{server.Name}:{tool.Name}";
                if (!tool.Enabled)
                {
                    McpSettingsProvider.Current.ToolDisabledStates.Add(toolKey);
                }
            }
        }
    }
}
