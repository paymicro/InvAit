@using Shared.Contracts.Mcp
@inherits RadzenComponent

<RadzenTabs RenderMode="TabRenderMode.Client">
    <Tabs>
    <RadzenTabsItem Text="General">
        <RadzenStack Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Subtitle1">Profile:</RadzenText>
                <RadzenDropDown Data="@_profiles" TextProperty="Name" ValueProperty="Id" 
                                @bind-Value="@_selectedProfileId" @bind-Value:after="@OnProfileChanged"
                                Style="flex: 1;" />
                <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat" Click="@OnAddProfile" ToolTip="Create new profile" />
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="@OnDeleteProfile" 
                              Disabled="@(_profiles.Count <= 1)" ToolTip="Delete current profile" />
            </RadzenStack>

            @if (_selectedProfile != null)
            {
                 <RadzenStack Gap="1rem">
                    <RadzenFormField Text="Profile Name" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="@_selectedProfile.Name" @bind-Value:after="@OnFieldChanged" Immediate Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenFormField Text="Provider" Variant="Variant.Outlined">
                        <RadzenDropDown @bind-Value="@_selectedProfile.Provider" Data="@_providers" @bind-Value:after="@OnProviderChanged" Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenFormField Text="Endpoint" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="@_selectedProfile.Endpoint" @bind-Value:after="@OnFieldChanged" Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenFormField Text="ApiKey" Variant="Variant.Outlined">
                        <RadzenPassword @bind-Value="@_selectedProfile.ApiKey" @bind-Value:after="@OnFieldChanged" Style="width: 100%" />
                    </RadzenFormField>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                        <RadzenDropDown TValue="string"
                                        Data="@ProfileManager.ActiveProfile.AvailableModels"
                                        @bind-Value="@_selectedProfile.Model"
                                        @bind-Value:after="@OnFieldChanged"
                                        Placeholder="Select model (type to add custom)"
                                        AllowCustomText="true"
                                        Style="width: 100%" />
                         <RadzenButton Icon="autorenew" Click="() => UpdateModelsAsync(CancellationToken.None)" ButtonStyle="ButtonStyle.Light" ToolTip="Refresh models from endpoint" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <RadzenCheckBox @bind-Value=@_selectedProfile.Stream Name="Stream" @bind-Value:after="@OnFieldChanged" />
                        <RadzenLabel Text="Use stream" Component="Stream" />
                    </RadzenStack>

                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <RadzenCheckBox @bind-Value=@_selectedProfile.SkipSSL Name="SkipSSL" @bind-Value:after="@OnFieldChanged" />
                        <RadzenLabel Text="Skip SSL validation" Component="SkipSSL" />
                    </RadzenStack>

                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="Temperature" />
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenSlider @bind-Value="@_selectedProfile.Temperature" Min="0" Max="2" Step="0.1" @bind-Value:after="@OnFieldChanged" Style="width: 100%; height: 20px;" />
                            <RadzenLabel Text="@Math.Abs(_selectedProfile.Temperature).ToString("0.0")" Style="text-align: right; width: 50px;" />
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="Max tokens" />
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenSlider @bind-Value="@_selectedProfile.MaxTokens" Min=1000 Max=1000000 Step="1000" @bind-Value:after="@OnFieldChanged" Style="width: 100%; height: 20px;" />
                            <RadzenLabel Text="@($"{_selectedProfile.MaxTokens / 1000}K")" Style="text-align: right; width: 50px;" />
                        </RadzenStack>
                    </RadzenStack>

                    <RadzenFormField Text="System prompt" Variant="Variant.Outlined">
                        <RadzenTextArea @bind-Value="@_selectedProfile.SystemPrompt" @bind-Value:after="@OnFieldChanged" Style="min-height: 90px" />
                    </RadzenFormField>
                </RadzenStack>
            }
        </RadzenStack>
    </RadzenTabsItem>
    <RadzenTabsItem Text="Built-in Tools">
        <RadzenStack Gap="1rem">
            @foreach (var category in Enum.GetValues<ToolCategory>())
            {
                var state = ToolManager.Current.CategoryStates.ContainsKey(category) 
                    ? ToolManager.Current.CategoryStates[category] 
                    : new ToolModeSettings();

                <RadzenStack Gap="0.5rem">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" >
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                            <RadzenLabel Text="@GetCategoryName(category)" Component="@($"cat_{category}")" Style="font-weight: 500; min-width: 150px;" />
                            <RadzenSwitch @bind-Value="@state.IsEnabled" @bind-Value:after="() => OnCategorySettingChanged(category, state)" Name="@($"cat_{category}")" />
                        </RadzenStack>

                        <RadzenDropDown TValue="ToolApprovalMode" Data="@(Enum.GetValues<ToolApprovalMode>())"
                                        @bind-Value="@state.ApprovalMode" @bind-Value:after="() => OnCategorySettingChanged(category, state)"
                                        Style="width: 150px; flex-shrink: 0;" />
                    </RadzenStack>

                    <div class="@(state.IsEnabled ? "category-tools-visible" : "category-tools-hidden")">
                        @if (state.IsEnabled)
                        {
                            var categoryTools = ToolManager.GetAllTools().Where(t => t.Category == category).ToList();
                            if (categoryTools.Count > 1)
                            {
                                <RadzenAccordion>
                                    <Items>
                                        <RadzenAccordionItem Text="@($"Specific Tools ({categoryTools.Count(t => t.Enabled)}/{categoryTools.Count})")" Icon="build">
                                            <RadzenStack Gap="0.5rem">
                                                @foreach (var tool in categoryTools)
                                                {
                                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                                        <RadzenCheckBox @bind-Value="@tool.Enabled" @bind-Value:after="() => OnToolSettingChanged(tool)" Name="@($"tool_{tool.Name}")" />
                                                        <RadzenLabel Text="@tool.Name" Component="@($"tool_{tool.Name}")" Style="font-size: 0.9rem; opacity: 0.8;" />
                                                    </RadzenStack>
                                                }
                                            </RadzenStack>
                                        </RadzenAccordionItem>
                                    </Items>
                                </RadzenAccordion>
                            }
                        }
                    </div>
                </RadzenStack>
            }
        </RadzenStack>
    </RadzenTabsItem>

    <RadzenTabsItem Text="MCP">
        <RadzenStack Gap="0.5rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenLabel Text="Enable MCP" Component="McpGlobalEnabled" />
                <RadzenSwitch @bind-Value="@McpSettingsProvider.Current.Enabled" Name="McpGlobalEnabled" />
            </RadzenStack>
            <RadzenButton Icon="add" Click="@OnAddMcpServer" ButtonStyle="ButtonStyle.Success" Disabled="@(!McpSettingsProvider.Current.Enabled)" />
            @if (McpSettingsProvider.Current.Enabled)
            {
                @foreach (var server in McpSettingsProvider.Current.Servers)
                {
                    <RadzenStack Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                <RadzenCheckBox @bind-Value="@server.Enabled" Name="@($"mcp_server_{server.Id}")" />
                                <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin: 0; font-weight: bold;">@server.Name</RadzenText>
                                @if (string.IsNullOrEmpty(server.Name))
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="New Server" />
                                }
                            </RadzenStack>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => OnEditMcpServer(server))" />
                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => OnDeleteMcpServer(server))" />
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Gap="0.2rem" Style="font-size: 0.8rem; color: var(--rz-text-secondary-color); padding-left: 2rem;">
                            <div>Transport: @server.Transport</div>
                            @if (server.Transport == "stdio")
                            {
                                <div>Command: @server.Command @server.Args</div>
                            }
                            else
                            {
                                <div>Endpoint: @server.Endpoint</div>
                            }
                        </RadzenStack>

                        @if (server.Tools.Any())
                        {
                            <RadzenAccordion Style="margin-top: 0.5rem; border: none;">
                                <Items>
                                    <RadzenAccordionItem Text="@($"Tools ({server.Tools.Count(t => t.Enabled)}/{server.Tools.Count})")" Icon="build">
                                        <RadzenStack Gap="0.5rem">
                                            @foreach (var tool in server.Tools)
                                            {
                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                                        <RadzenCheckBox @bind-Value="@tool.Enabled" @bind-Value:after="OnMcpToolSettingChanged" Name="@($"mcp_tool_{server.Id}_{tool.Name}")" />
                                                        <RadzenLabel Text="@tool.Name" Component="@($"mcp_tool_{server.Id}_{tool.Name}")" />
                                                    </RadzenStack>
                                                    <RadzenText TextStyle="TextStyle.Caption" Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 60%;">@tool.Description</RadzenText>
                                                </RadzenStack>
                                            }
                                        </RadzenStack>
                                    </RadzenAccordionItem>
                                </Items>
                            </RadzenAccordion>
                        }
                    </RadzenStack>
                }
            }
        </RadzenStack>
    </RadzenTabsItem>
    <RadzenTabsItem Text="UI">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenLabel Text="Theme" Style="margin-right: 0.5rem;" />
            <RadzenAppearanceToggle Variant="Variant.Text" ButtonStyle="ButtonStyle.Base" />
        </RadzenStack>
    </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code
{
    [Inject] ChatService ChatService { get; set; } = null!;
    [Inject] NotificationService NotificationService { get; set; } = null!;
    [Inject] IToolManager ToolManager { get; set; } = null!;
    [Inject] IProfileManager ProfileManager { get; set; } = null!;
    [Inject] DialogService DialogService { get; set; } = null!;
    [Inject] IMcpSettingsProvider McpSettingsProvider { get; set; } = null!;

    private List<ConnectionProfile> _profiles = [];
    private ConnectionProfile? _selectedProfile;
    private string _selectedProfileId = string.Empty;
    private readonly List<string> _providers = ["OpenAI Compatible"];

    protected override async Task OnInitializedAsync()
    {
        await LoadProfilesAsync();
    }

    private async Task OnAddMcpServer()
    {
        var newServer = new McpServerConfig { Name = "New MCP Server" };
        var result = await DialogService.OpenAsync<McpServerDialog>("Add MCP Server", 
            new Dictionary<string, object> { { "Server", newServer } });

        if (result == true)
        {
            McpSettingsProvider.Current.Servers.Add(newServer);
            await McpSettingsProvider.SaveAsync();
            StateHasChanged();
        }
    }

    private async Task OnEditMcpServer(McpServerConfig server)
    {
        // Clone for editing
        var editServer = new McpServerConfig
        {
            Id = server.Id,
            Name = server.Name,
            Transport = server.Transport,
            Command = server.Command,
            Args = server.Args,
            Endpoint = server.Endpoint,
            Enabled = server.Enabled,
            Tools = server.Tools
        };

        var result = await DialogService.OpenAsync<McpServerDialog>("Edit MCP Server", 
            new Dictionary<string, object> { { "Server", editServer } });

        if (result == true)
        {
            server.Name = editServer.Name;
            server.Transport = editServer.Transport;
            server.Command = editServer.Command;
            server.Args = editServer.Args;
            server.Endpoint = editServer.Endpoint;
            await McpSettingsProvider.SaveAsync();
            StateHasChanged();
        }
    }

    private async Task OnDeleteMcpServer(McpServerConfig server)
    {
        var confirm = await DialogService.Confirm($"Are you sure you want to delete '{server.Name}'?", "Delete MCP Server");
        if (confirm == true)
        {
            McpSettingsProvider.Current.Servers.Remove(server);
            await McpSettingsProvider.SaveAsync();
            StateHasChanged();
        }
    }

    private async Task LoadProfilesAsync()
    {
        _profiles = await ProfileManager.GetProfilesAsync();
        var activeId = await ProfileManager.GetActiveProfileIdAsync();

        if (string.IsNullOrEmpty(activeId) || !_profiles.Any(p => p.Id == activeId))
        {
            _selectedProfile = _profiles.FirstOrDefault();
        }
        else
        {
            _selectedProfile = _profiles.First(p => p.Id == activeId);
        }

        if (_selectedProfile != null)
        {
            _selectedProfileId = _selectedProfile.Id;
            // Ensure global settings match selected profile initially
            if (activeId != _selectedProfileId)
            {
                 await ProfileManager.ActivateProfileAsync(_selectedProfileId);
            }
        }
    }

    private async Task OnProfileChanged()
    {
        var id = _selectedProfileId;
        if (!string.IsNullOrEmpty(id))
        {
            _selectedProfile = _profiles.FirstOrDefault(p => p.Id == id);
            if (_selectedProfile != null)
            {
                await ProfileManager.ActivateProfileAsync(id);
                StateHasChanged();
            }
        }
    }

    private async Task OnAddProfile()
    {
        var newProfile = new ConnectionProfile();
        await ProfileManager.SaveProfileAsync(newProfile);
        await LoadProfilesAsync();
        
        // Select the new profile
        _selectedProfileId = newProfile.Id;
        await OnProfileChanged();
    }

    private async Task OnDeleteProfile()
    {
         if (_profiles.Count <= 1) return;

         var confirm = await DialogService.Confirm($"Are you sure you want to delete '{_selectedProfile?.Name}'?", "Delete Profile", 
            new ConfirmOptions() { OkButtonText = "Yes", CancelButtonText = "No" });

         if (confirm == true && _selectedProfile != null)
         {
             await ProfileManager.DeleteProfileAsync(_selectedProfile.Id);
             await LoadProfilesAsync();
         }
    }

    private async Task OnFieldChanged()
    {
        if (_selectedProfile != null)
        {
            await ProfileManager.SaveProfileAsync(_selectedProfile);
        }
    }

    private async Task OnProviderChanged()
    {
        if (_selectedProfile != null)
        {
             switch (_selectedProfile.Provider)
            {
                case "OpenAI Compatible":
                    _selectedProfile.Endpoint = "https://api.openai.com";
                    break;
            }
            await OnFieldChanged();
        }
    }

    private async Task UpdateModelsAsync(CancellationToken cancellationToken)
    {
        try
        {
            // Note: This uses the CURRENT options in ProfileManager. 
            // Since we call ActivateProfileAsync/SaveProfileAsync on change, 
            // the settings are already active.
            var models = await ChatService.GetModelsAsync(cancellationToken);
            var list = models.Data.Select(m => m.Id).ToList();
            
            // Allow Custom Models logic?
            ProfileManager.ActiveProfile.AvailableModels = list;
             
             if (!list.Contains(_selectedProfile!.Model))
             {
                 _selectedProfile.Model = list.FirstOrDefault() ?? "";
                 await OnFieldChanged();
             }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Models not found",
                Detail = ex.Message,
                Duration = 10_000,
                ShowProgress = true,
            });
        }
        StateHasChanged();
    }

    private string GetCategoryName(ToolCategory category)
    {
        return category switch
        {
            ToolCategory.ReadFiles => "Чтение файлов",
            ToolCategory.WriteFiles => "Запись файлов",
            ToolCategory.DeleteFiles => "Удаление файлов",
            ToolCategory.Browser => "Браузер",
            ToolCategory.Mcp => "MCP",
            ToolCategory.ModeSwitch => "Смена режима",
            ToolCategory.Execution => "Выполнение",
            _ => category.ToString()
        };
    }

    private async Task OnCategorySettingChanged(ToolCategory category, ToolModeSettings state)
    {
        ToolManager.UpdateCategorySettings(category, state.IsEnabled, state.ApprovalMode);
        await Task.CompletedTask;
    }

    private async Task OnToolSettingChanged(Tool tool)
    {
        ToolManager.ToggleTool(tool.Name, tool.Enabled);
        await Task.CompletedTask;
    }

    private async Task OnMcpToolSettingChanged()
    {
        // TODO сделать отложенное сохранение как в ToolManager выше
        await McpSettingsProvider.SaveAsync();
    }
}
