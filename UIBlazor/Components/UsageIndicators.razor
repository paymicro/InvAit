<div class="usage-indicators">
    <div class="usage-item" title="@SharedResource.Messages: @Messages.Count / @ProfileManager.ActiveProfile.MaxMessages">
        <div class="usage-label">
            <span>@SharedResource.Messages</span>
            <span>@Messages.Count / @ProfileManager.ActiveProfile.MaxMessages</span>
        </div>
        <div class="usage-bar-container">
            <div class="usage-bar" style="width: @(MessageProgress)%;"></div>
        </div>
    </div>
    <div class="usage-item" title="@SharedResource.Tokens: @ChatService.Session?.TotalTokens / @ProfileManager.ActiveProfile.ContextWindow">
        <div class="usage-label">
            <span>@SharedResource.Tokens</span>
            <span>@(ChatService.Session?.TotalTokens ?? 0) / @ProfileManager.ActiveProfile.ContextWindow</span>
        </div>
        <div class="usage-bar-container">
            <div class="usage-bar" style="width: @(TokenProgress)%; background: var(--rz-secondary);"></div>
        </div>
    </div>
</div>

@code {
    [Inject] IProfileManager ProfileManager { get; set; } = null!;
    [Inject] IChatService ChatService { get; set; } = null!;

    [Parameter] public List<VisualChatMessage> Messages { get; set; } = [];

    private int MessageProgress => ProfileManager.ActiveProfile.MaxMessages > 0
        ? Math.Min(100, Messages.Count * 100 / ProfileManager.ActiveProfile.MaxMessages)
        : 0;

    private int TokenProgress => ProfileManager.ActiveProfile.ContextWindow > 0
        ? Math.Min(100, ChatService.Session.TotalTokens * 100 / ProfileManager.ActiveProfile.ContextWindow)
        : 0;
}