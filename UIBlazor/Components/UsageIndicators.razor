<div class="usage-indicators">
    @if (ProfileManager.ActiveProfile.TokensToCompress > 0)
    {
        <div class="usage-item" title="@SharedResource.CompressionTokenThreshold: @(ChatService.Session?.TotalTokens ?? 0) / @ProfileManager.ActiveProfile.TokensToCompress">
            <div class="usage-label">
                <span>@SharedResource.CompressionTokenThreshold</span>
                <span>@(ChatService.Session?.TotalTokens ?? 0) / @ProfileManager.ActiveProfile.TokensToCompress</span>
            </div>
            <div class="usage-bar-container">
                <div class="usage-bar" style="width: @(MessageProgress)%;"></div>
            </div>
        </div>
    }
    <div class="usage-item" title="@SharedResource.ContextWindow: @ChatService.Session?.TotalTokens / @ProfileManager.ActiveProfile.ContextWindow">
        <div class="usage-label">
            <span>@SharedResource.ContextWindow</span>
            <span>@(ChatService.Session?.TotalTokens ?? 0) / @ProfileManager.ActiveProfile.ContextWindow</span>
        </div>
        <div class="usage-bar-container">
            <div class="usage-bar" style="width: @(TokenProgress)%;"></div>
        </div>
    </div>
</div>

@code {
    [Inject] IProfileManager ProfileManager { get; set; } = null!;
    [Inject] IChatService ChatService { get; set; } = null!;

    [Parameter] public List<VisualChatMessage> Messages { get; set; } = [];

    private int MessageProgress => ProfileManager.ActiveProfile.TokensToCompress > 0
        ? Math.Min(100, ChatService.Session.TotalTokens * 100 / ProfileManager.ActiveProfile.TokensToCompress)
        : 0;

    private int TokenProgress => ProfileManager.ActiveProfile.ContextWindow > 0
        ? Math.Min(100, ChatService.Session.TotalTokens * 100 / ProfileManager.ActiveProfile.ContextWindow)
        : 0;
}