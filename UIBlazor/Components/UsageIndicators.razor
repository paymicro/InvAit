@inject ChatService ChatService

<div class="usage-indicators">
    <div class="usage-item" title="Messages: @Messages.Count / @ChatService.Options.MaxMessages">
        <div class="usage-label">
            <span>Messages</span>
            <span>@Messages.Count / @ChatService.Options.MaxMessages</span>
        </div>
        <div class="usage-bar-container">
            <div class="usage-bar" style="width: @(MessageProgress)%;"></div>
        </div>
    </div>
    <div class="usage-item" title="Tokens: @ChatService.Session?.TotalTokens / @ChatService.Options.MaxTokens">
        <div class="usage-label">
            <span>Tokens</span>
            <span>@(ChatService.Session?.TotalTokens ?? 0) / @ChatService.Options.MaxTokens</span>
        </div>
        <div class="usage-bar-container">
            <div class="usage-bar" style="width: @(TokenProgress)%; background: var(--rz-secondary);"></div>
        </div>
    </div>
</div>

@code {
    [Parameter] public List<VisualChatMessage> Messages { get; set; } = [];

    private int MessageProgress => ChatService.Session != null && ChatService.Options.MaxMessages > 0
        ? Math.Min(100, Messages.Count * 100 / ChatService.Options.MaxMessages)
        : 0;

    private int TokenProgress => ChatService.Session != null && ChatService.Options.MaxTokens > 0
        ? Math.Min(100, ChatService.Session.TotalTokens * 100 / ChatService.Options.MaxTokens)
        : 0;
}